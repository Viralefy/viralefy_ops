#!/usr/bin/env bash
# viralefy-update — deploy ZERO-DOWNTIME via staging-then-swap.
#
# Estratégia: build inteiro acontece em /viralefy.next/ enquanto os
# serviços continuam rodando no /viralefy/ atual. Só na hora da troca
# (uns ~5s) é que os serviços reiniciam.
#
# Fluxo:
#   1. Clona todos os repos pra /viralefy.next/ (paralelo aos serviços live).
#   2. Build da API + front + backoffice em /viralefy.next/.
#   3. Atomic swap:
#        systemctl stop {api,front,backoffice}    # ~1s
#        mv /viralefy → /viralefy.prev             # instant (same FS)
#        mv /viralefy.next → /viralefy             # instant
#        systemctl start {api,front,backoffice}    # ~3s
#   4. Healthcheck. Se falhar, rollback automatic (mv /viralefy.prev → /viralefy).
#   5. Cleanup .prev em background.
#
# Para emergência (build quebrado, rebuild total): use viralefy-update --legacy
# que faz o destrutivo antigo.

set -euo pipefail
IFS=$'\n\t'

ROOT_DIR=/viralefy
NEXT_DIR=/viralefy.next
PREV_DIR=/viralefy.prev
ENV_FILE=/etc/viralefy/.env
LEGACY_MARKER=/etc/viralefy/.legacy-deprecated
ORG="${VIRALEFY_GH_ORG:-Viralefy}"
REPO_BASE="${VIRALEFY_REPO_BASE:-https://github.com/$ORG}"
BRANCH="${VIRALEFY_BRANCH:-main}"

# --include-legacy: força build+deploy do viralefy-api mesmo com marker
# $LEGACY_MARKER presente. Sem essa flag, se o marker existir, o api é
# clonado mas NÃO buildado nem deployado (cutover PHASE-9 em soak).
INCLUDE_LEGACY=0
ARGS=()
for arg in "$@"; do
  case "$arg" in
    --include-legacy) INCLUDE_LEGACY=1 ;;
    *) ARGS+=("$arg") ;;
  esac
done
set -- "${ARGS[@]+"${ARGS[@]}"}"

# SKIP_API=1 quando marker existe e operador não passou --include-legacy.
# O clone do viralefy_api continua acontecendo (pra source ficar atualizado
# em /viralefy/api e commits visíveis), mas:
#   - build_api é skipado
#   - systemctl stop/start de viralefy-api é skipado
#   - healthcheck da porta 8080 (api) é skipado
SKIP_API=0
if [[ -f "$LEGACY_MARKER" && $INCLUDE_LEGACY -eq 0 ]]; then
  SKIP_API=1
fi

[[ $EUID -eq 0 ]] || { echo "Precisa rodar como root."; exit 1; }

# Modo legacy: comportamento antigo destrutivo. Usado em emergência.
if [[ "${1:-}" == "--legacy" ]]; then
  echo "[legacy] modo destrutivo solicitado"
  systemctl stop viralefy-api viralefy-payments viralefy-sender viralefy-front viralefy-backoffice 2>/dev/null || true
  rm -rf "$ROOT_DIR/api" "$ROOT_DIR/payments" "$ROOT_DIR/sender" "$ROOT_DIR/front" "$ROOT_DIR/backoffice" "$ROOT_DIR/ops" "$ROOT_DIR/archive"
  STAGE="$(mktemp -d /tmp/viralefy-ops.XXXXXX)"
  trap 'rm -rf "$STAGE"' EXIT
  git clone --depth 1 --branch "$BRANCH" "$REPO_BASE/viralefy_ops.git" "$STAGE" >/dev/null
  [[ -f "$ENV_FILE" ]] && { set -a; source "$ENV_FILE"; set +a; }
  exec "$STAGE/bin/viralefy-install"
fi

# Confirmação interativa
if [[ -t 0 && "${1:-}" != "--yes" ]]; then
  echo "Deploy zero-downtime: build em $NEXT_DIR, swap atômico."
  echo "Downtime estimado: ~5s (stop + mv + start)."
  read -r -p "Continuar? [y/N] " ans
  [[ "$ans" == "y" || "$ans" == "Y" ]] || { echo "abortado."; exit 1; }
fi

ts() { date -u +"%H:%M:%S"; }
log() { echo "[$(ts)] $*"; }

if [[ $SKIP_API -eq 1 ]]; then
  log "MODO LEGACY-SKIP: marker $LEGACY_MARKER existe — viralefy-api não será buildado nem deployado (use --include-legacy pra forçar)."
elif [[ $INCLUDE_LEGACY -eq 1 ]]; then
  log "--include-legacy: forçando build+deploy de viralefy-api mesmo com marker presente."
fi

log "limpando staging anterior"
rm -rf "$NEXT_DIR" "$PREV_DIR"
install -d -m 0755 -o root -g root "$NEXT_DIR"

log "carregando segredos"
[[ -f "$ENV_FILE" ]] || { echo ".env ausente em $ENV_FILE"; exit 1; }
# shellcheck disable=SC1090
set -a; source "$ENV_FILE"; set +a

# ---------- Clones em paralelo ---------- #
# 10 repos: 7 legacy (api/front/backoffice/payments/sender/ops/archive) +
# 3 PHASE-9 (core/auth/dispatcher). PHASE-9 são tolerantes a erro de clone
# (repo pode ser private/missing em ambientes < phase-9-ready) — fall back
# silenciosa pra continuar o deploy legacy.
log "clonando repos em paralelo pra $NEXT_DIR"
clone_one() {
  local repo="$1" pkg="$2" user="$3"
  git clone --quiet --depth 1 --branch "$BRANCH" "$REPO_BASE/$repo.git" "$NEXT_DIR/$pkg"
  chown -R "$user:viralefy" "$NEXT_DIR/$pkg"
}
clone_optional() {
  local repo="$1" pkg="$2" user="$3"
  if git clone --quiet --depth 1 --branch "$BRANCH" "$REPO_BASE/$repo.git" "$NEXT_DIR/$pkg" 2>/dev/null; then
    chown -R "$user:viralefy" "$NEXT_DIR/$pkg"
  else
    echo "[warn] $repo não disponível — pulando (PHASE-9 ainda não pronto pra este host)"
  fi
}
clone_one viralefy_api        api        viralefy-api &
clone_one viralefy_payments   payments   viralefy-payments &
clone_one viralefy_sender     sender     viralefy-sender &
clone_one viralefy_front      front      viralefy-front &
clone_one viralefy_backoffice backoffice viralefy-backoffice &
clone_one viralefy_ops        ops        root &
clone_one viralefy_archive    archive    root &
clone_optional viralefy_core       core       viralefy-core &
clone_optional viralefy_auth       auth       viralefy-auth &
clone_optional viralefy_dispatcher dispatcher viralefy-dispatcher &
wait
log "clones ok"

# ---------- Builds em paralelo ---------- #
log "buildando API + payments + sender (Go) + front + backoffice em paralelo"

build_api() {
  local d="$NEXT_DIR/api"
  install -d -m 0755 -o viralefy-api -g viralefy "$d/bin"
  sudo -u viralefy-api -H env PATH="/usr/local/go/bin:$PATH" \
    bash -c "cd '$d' && go build -trimpath -ldflags='-s -w' -o bin/viralefy-api ./cmd/api"
}

# Build genérico Go pros microservices (payments, sender). Mesmo pattern
# do build_api; o binário fica em /viralefy.next/<pkg>/bin/ e será copiado
# pra /usr/local/sbin/ pelo 60-systemd.sh durante o swap (o ExecStart dos
# units aponta lá).
build_go_svc() {
  local pkg="$1" cmd_path="$2"
  local d="$NEXT_DIR/$pkg" user="viralefy-$pkg" bin="viralefy-$pkg"
  install -d -m 0755 -o "$user" -g viralefy "$d/bin"
  sudo -u "$user" -H env PATH="/usr/local/go/bin:$PATH" \
    bash -c "cd '$d' && go build -trimpath -ldflags='-s -w' -o bin/$bin ./$cmd_path"
}

build_node() {
  local pkg="$1" user="viralefy-$1" d="$NEXT_DIR/$1"
  # .env.local com NEXT_PUBLIC_* pro build-time
  install -m 0640 -o "$user" -g viralefy /dev/null "$d/.env.local"
  { grep -E '^NEXT_PUBLIC_' "$ENV_FILE" || true; } > "$d/.env.local"
  chown "$user:viralefy" "$d/.env.local"
  sudo -u "$user" -H bash -c "cd '$d' && npm ci --no-audit --no-fund --silent && npm run build --silent"
}

# Build de cron auxiliar do viralefy_core (reconcile, user-deletion). Mesmo
# user/PATH do build_go_svc core, mas os binários têm nome próprio (não seguem
# convenção viralefy-<pkg>) porque são CLIs distintos do daemon. Skip silencioso
# se o cmd/ ainda não existe (clients pré-migrations 042/043).
#
# Args: <bin_name> <cmd_subdir>
#   ex: build_core_cron viralefy-reconcile reconcile-cron
build_core_cron() {
  local bin="$1" sub="$2"
  local d="$NEXT_DIR/core"
  if [[ ! -d "$d/cmd/$sub" ]]; then
    echo "[skip] build $bin: cmd/$sub ausente (HEAD < migration cron)"
    return 0
  fi
  sudo -u viralefy-core -H env PATH="/usr/local/go/bin:$PATH" \
    bash -c "cd '$d' && go build -trimpath -ldflags='-s -w' -o bin/$bin ./cmd/$sub"
  echo "[ok] build $bin"
}

# Build de Rust binary (dispatcher). cargo é instalado por bootstrap.sh quando
# PHASE-9 estiver ativo; se não tiver cargo, skip silencioso.
build_rust_svc() {
  local pkg="$1" cmd_path="$2"
  local d="$NEXT_DIR/$pkg" user="viralefy-$pkg" bin="viralefy-$pkg"
  install -d -m 0755 -o "$user" -g viralefy "$d/bin"
  if ! command -v cargo >/dev/null 2>&1; then
    echo "[skip] cargo ausente — pulando build $pkg"
    return 0
  fi
  sudo -u "$user" -H env PATH="$HOME/.cargo/bin:$PATH" \
    bash -c "cd '$d' && cargo build --release 2>&1 && cp -f target/release/$bin bin/$bin"
}

PID_API=""
if [[ $SKIP_API -eq 1 ]]; then
  log "viralefy-api: LEGACY em soak (marker $LEGACY_MARKER existe). Skip build. Clone preservado."
else
  build_api > /tmp/build-api.log 2>&1 &
  PID_API=$!
fi
build_go_svc payments cmd/payments > /tmp/build-payments.log 2>&1 &
PID_PAY=$!
build_go_svc sender cmd/sender > /tmp/build-sender.log 2>&1 &
PID_SND=$!
build_node front > /tmp/build-front.log 2>&1 &
PID_FRONT=$!
build_node backoffice > /tmp/build-backoffice.log 2>&1 &
PID_BACK=$!

# PHASE-9 builds: core (Go), auth (Go), dispatcher (Rust). Cada um só roda
# se o clone foi bem-sucedido. Falha aqui NÃO bloqueia o deploy legacy.
PID_CORE=""; PID_AUTH=""; PID_DISP=""
if [[ -d "$NEXT_DIR/core" ]]; then
  build_go_svc core cmd/core > /tmp/build-core.log 2>&1 &
  PID_CORE=$!
fi
# Crons auxiliares do core (Go) — build em background junto. Nomes
# diferem do pkg ("viralefy-reconcile", "viralefy-user-deletion") porque
# são CLIs separados, não o daemon. Tolerante: se cmd/ não existir, skip
# silencioso (clients < migration 042/043). Antes era scp manual.
PID_RECON=""; PID_UDEL=""; PID_OANON=""; PID_TCLEAN=""
if [[ -d "$NEXT_DIR/core" ]]; then
  build_core_cron viralefy-reconcile reconcile-cron \
    > /tmp/build-reconcile.log 2>&1 &
  PID_RECON=$!
  build_core_cron viralefy-user-deletion user-deletion-cron \
    > /tmp/build-user-deletion.log 2>&1 &
  PID_UDEL=$!
  build_core_cron viralefy-orders-anonymize orders-anonymize-cron \
    > /tmp/build-orders-anonymize.log 2>&1 &
  PID_OANON=$!
  # 2026-06-11: cleanup hourly de fixtures *@viralefy.test deixadas pelo
  # smoke E2E (POST /v1/checkout regression test Coraza FP 942100).
  build_core_cron viralefy-test-cleanup test-cleanup-cron \
    > /tmp/build-test-cleanup.log 2>&1 &
  PID_TCLEAN=$!
fi
if [[ -d "$NEXT_DIR/auth" ]]; then
  build_go_svc auth cmd/auth > /tmp/build-auth.log 2>&1 &
  PID_AUTH=$!
fi
if [[ -d "$NEXT_DIR/dispatcher" ]]; then
  build_rust_svc dispatcher . > /tmp/build-dispatcher.log 2>&1 &
  PID_DISP=$!
fi

# Espera + checa exit codes (paralelismo seguro)
FAIL=0
if [[ -n "$PID_API" ]]; then
  wait $PID_API || { echo "FALHA build API"; tail -30 /tmp/build-api.log; FAIL=1; }
fi
wait $PID_PAY || { echo "FALHA build payments"; tail -30 /tmp/build-payments.log; FAIL=1; }
wait $PID_SND || { echo "FALHA build sender"; tail -30 /tmp/build-sender.log; FAIL=1; }
wait $PID_FRONT || { echo "FALHA build front"; tail -30 /tmp/build-front.log; FAIL=1; }
wait $PID_BACK || { echo "FALHA build backoffice"; tail -30 /tmp/build-backoffice.log; FAIL=1; }

# PHASE-9 build waits — NÃO derrubam deploy legacy se falharem (avisamos só).
PHASE9_FAIL=0
if [[ -n "$PID_CORE" ]]; then
  wait $PID_CORE || { echo "[warn] FALHA build core (não bloqueia legacy)"; tail -20 /tmp/build-core.log; PHASE9_FAIL=1; }
fi
if [[ -n "$PID_AUTH" ]]; then
  wait $PID_AUTH || { echo "[warn] FALHA build auth (não bloqueia legacy)"; tail -20 /tmp/build-auth.log; PHASE9_FAIL=1; }
fi
if [[ -n "$PID_DISP" ]]; then
  wait $PID_DISP || { echo "[warn] FALHA build dispatcher (não bloqueia legacy)"; tail -20 /tmp/build-dispatcher.log; PHASE9_FAIL=1; }
fi
if [[ -n "$PID_RECON" ]]; then
  wait $PID_RECON || { echo "[warn] FALHA build reconcile-cron (não bloqueia legacy)"; tail -20 /tmp/build-reconcile.log; PHASE9_FAIL=1; }
fi
if [[ -n "$PID_UDEL" ]]; then
  wait $PID_UDEL || { echo "[warn] FALHA build user-deletion-cron (não bloqueia legacy)"; tail -20 /tmp/build-user-deletion.log; PHASE9_FAIL=1; }
fi
if [[ -n "$PID_OANON" ]]; then
  wait $PID_OANON || { echo "[warn] FALHA build orders-anonymize-cron (não bloqueia legacy)"; tail -20 /tmp/build-orders-anonymize.log; PHASE9_FAIL=1; }
fi
if [[ -n "$PID_TCLEAN" ]]; then
  wait $PID_TCLEAN || { echo "[warn] FALHA build test-cleanup-cron (não bloqueia legacy)"; tail -20 /tmp/build-test-cleanup.log; PHASE9_FAIL=1; }
fi

if [[ $FAIL -eq 1 ]]; then
  echo "Build falhou. /viralefy/ atual intocado. Staging em $NEXT_DIR."
  exit 1
fi

log "builds ok — preparando swap"

# ---------- ATOMIC SWAP (downtime aqui) ---------- #
log "swap: stop → mv → start"

# Ordem de stop: api primeiro (depende dos microservices), depois os deps.
# Quando SKIP_API=1 (PHASE-9 cutover em soak), viralefy-api já está stopped
# + disabled — não mexer pra não re-introduzir o serviço no journal.
if [[ $SKIP_API -eq 1 ]]; then
  systemctl stop viralefy-front viralefy-backoffice \
                 viralefy-payments viralefy-sender 2>/dev/null || true
else
  systemctl stop viralefy-api viralefy-front viralefy-backoffice \
                 viralefy-payments viralefy-sender 2>/dev/null || true
fi

# Salva ops anterior pra rollback caso healthcheck falhe.
if [[ -d $ROOT_DIR ]]; then
  mv "$ROOT_DIR" "$PREV_DIR"
fi
mv "$NEXT_DIR" "$ROOT_DIR"

# Copia binários dos microservices pra /usr/local/sbin (ExecStart dos units
# aponta lá). API tem ExecStart em /viralefy/api/bin/viralefy-api (in-place).
# PHASE-9: core/auth/dispatcher também copiados pra /usr/local/sbin pra
# que systemd units consigam executar mesmo após `rm -rf /viralefy/<pkg>`.
for pkg in payments sender core auth dispatcher; do
  if [[ -x "$ROOT_DIR/$pkg/bin/viralefy-$pkg" ]]; then
    install -m 0755 -o root -g root \
      "$ROOT_DIR/$pkg/bin/viralefy-$pkg" "/usr/local/sbin/viralefy-$pkg"
  fi
done
# Crons auxiliares do core (timers systemd apontam pra estes binários).
# Backup do binário anterior antes do replace pra rollback rápido se o cron
# crashar (timer não tem healthcheck loopback). install já é atomic (rename
# via syscall) mas o .prev sobrevive ao swap pra inspeção / rollback manual.
for cron_bin in viralefy-reconcile viralefy-user-deletion viralefy-orders-anonymize viralefy-test-cleanup; do
  src="$ROOT_DIR/core/bin/$cron_bin"
  dst="/usr/local/sbin/$cron_bin"
  if [[ -x "$src" ]]; then
    [[ -x "$dst" ]] && cp -f "$dst" "$dst.prev" 2>/dev/null || true
    install -m 0755 -o root -g root "$src" "$dst"
    log "installed $cron_bin → $dst"
  else
    log "skip install $cron_bin: $src ausente"
  fi
done

# Re-instala systemd units (caso ops tenha mudado) — idempotente.
"$ROOT_DIR/ops/installer/60-systemd.sh" >/dev/null 2>&1 || \
  bash "$ROOT_DIR/ops/installer/60-systemd.sh" >/dev/null 2>&1 || true
systemctl daemon-reload

# Garante que timers PHASE-9 estejam enabled — idempotente. Hosts antigos
# podem nunca ter enabled o orders-anonymize na primeira passagem; este
# loop conserta sem precisar de runbook manual.
for timer in viralefy-reconcile.timer viralefy-user-deletion.timer viralefy-orders-anonymize.timer viralefy-test-cleanup.timer; do
  if [[ -f "/etc/systemd/system/$timer" ]]; then
    systemctl enable "$timer" >/dev/null 2>&1 || true
    systemctl start  "$timer" >/dev/null 2>&1 || true
  fi
done

# Sincroniza Caddyfile (ops repo é a source of truth). Sem isso, mudanças
# em handle_path / reverse_proxy / new route não chegam em prod sem ssh
# manual + cp. caddy validate antes de reload pra não rebootar com config
# quebrado. Reload é graceful — não derruba conexões em flight.
if [[ -f "$ROOT_DIR/ops/config/Caddyfile" ]]; then
  if ! diff -q "$ROOT_DIR/ops/config/Caddyfile" /etc/caddy/Caddyfile >/dev/null 2>&1; then
    if caddy validate --config "$ROOT_DIR/ops/config/Caddyfile" --envfile /etc/caddy/viralefy.env >/dev/null 2>&1; then
      cp "$ROOT_DIR/ops/config/Caddyfile" /etc/caddy/Caddyfile
      systemctl reload caddy
      echo "[ok] Caddyfile atualizado + reload"
    else
      echo "[warn] Caddyfile no repo NÃO valida — mantendo /etc/caddy/Caddyfile atual"
    fi
  fi
fi

# Migrations ANTES de subir qualquer serviço (DR drill 2026-06-10):
#   - viralefy-api migrate up      → schema legacy (001..038)
#   - viralefy-core migrate up     → 039_auth_tokens, 040_proof_storage_key
# refresh_tokens (em 039) é precondição de viralefy-auth subir. Sem isso,
# auth crasha no schema assert e o cutover PHASE-9 falha.
# Idempotente; falha hard em api migrate; tolerante a core ausente (legacy host).
log "migrations: api → core (precondição do auth)"
if [[ -x /viralefy/api/bin/viralefy-api ]]; then
  sudo -u viralefy-api bash -c "set -a; source '$ENV_FILE'; set +a; /viralefy/api/bin/viralefy-api migrate up" \
    || { echo "[fatal] viralefy-api migrate up falhou"; exit 1; }
fi
if [[ -x /usr/local/sbin/viralefy-core ]]; then
  sudo -u viralefy-core bash -c "set -a; source '$ENV_FILE'; set +a; /usr/local/sbin/viralefy-core migrate up" \
    || { echo "[fatal] viralefy-core migrate up falhou — auth não vai subir"; exit 1; }
fi

# Microservices primeiro (deps do api).
systemctl start viralefy-payments viralefy-sender
if [[ $SKIP_API -eq 1 ]]; then
  log "skip start viralefy-api (marker $LEGACY_MARKER presente)"
  systemctl start viralefy-front viralefy-backoffice
else
  systemctl start viralefy-api viralefy-front viralefy-backoffice
fi

# ---------- Healthcheck + rollback ---------- #
log "aguardando healthcheck (max 30s)"
HEALTHY=0
for i in $(seq 1 30); do
  ok=1
  curl -fsS http://127.0.0.1:8081/internal/health >/dev/null 2>&1 || ok=0
  curl -fsS http://127.0.0.1:8082/internal/health >/dev/null 2>&1 || ok=0
  if [[ $SKIP_API -eq 0 ]]; then
    curl -fsS http://127.0.0.1:8080/health >/dev/null 2>&1 || ok=0
  fi
  curl -fsS http://127.0.0.1:3000/ >/dev/null 2>&1 || ok=0
  if [[ $ok -eq 1 ]]; then HEALTHY=1; break; fi
  sleep 1
done

if [[ $HEALTHY -eq 0 ]]; then
  echo "healthcheck falhou — fazendo rollback"
  if [[ $SKIP_API -eq 1 ]]; then
    systemctl stop viralefy-front viralefy-backoffice \
                   viralefy-payments viralefy-sender
  else
    systemctl stop viralefy-api viralefy-front viralefy-backoffice \
                   viralefy-payments viralefy-sender
  fi
  rm -rf "$ROOT_DIR"
  mv "$PREV_DIR" "$ROOT_DIR"
  # Restaura binários antigos dos microservices se existirem.
  for pkg in payments sender; do
    if [[ -x "$ROOT_DIR/$pkg/bin/viralefy-$pkg" ]]; then
      install -m 0755 -o root -g root \
        "$ROOT_DIR/$pkg/bin/viralefy-$pkg" "/usr/local/sbin/viralefy-$pkg"
    fi
  done
  systemctl daemon-reload
  systemctl start viralefy-payments viralefy-sender
  if [[ $SKIP_API -eq 1 ]]; then
    systemctl start viralefy-front viralefy-backoffice
  else
    systemctl start viralefy-api viralefy-front viralefy-backoffice
  fi
  echo "rollback completo. Logs do build em /tmp/build-*.log."
  exit 1
fi

log "deploy ok ✓"

# Smoke check pós-deploy: contrato HTTP dos 3 services + endpoint público
# + auth gate. Falha aqui é grave — não fazemos rollback automático (o
# healthcheck loopback já passou), mas devolvemos exit 1 pra CI/operador
# investigar antes de declarar deploy verde.
SMOKE_BIN="/usr/local/sbin/viralefy-smoke"
[[ -x "$SMOKE_BIN" ]] || SMOKE_BIN="$ROOT_DIR/ops/bin/viralefy-smoke"
if [[ -x "$SMOKE_BIN" ]]; then
  log "rodando smoke check ($SMOKE_BIN)"
  if ! "$SMOKE_BIN"; then
    echo "[warn] smoke falhou — services up mas contrato HTTP quebrado"
    echo "[warn] investigue 'journalctl -u viralefy-{api,payments,sender} -n 50'"
    exit 1
  fi
fi

# Cleanup em background, não bloqueia
(rm -rf "$PREV_DIR" 2>/dev/null) &

# Obs stack só roda se invocado explicitamente — não toca em cada deploy.
echo "[ok] Stack zero-downtime. Próximo deploy: mesmo comando."
