#!/usr/bin/env bash
# Tail dos logs dos serviços via journalctl.
# Uso:  viralefy-logs                # todos viralefy-*
#       viralefy-logs api             # só api
#       viralefy-logs caddy           # Caddy
#       viralefy-logs front -n 200    # front com 200 linhas
set -uo pipefail

mapper() {
  case "${1:-all}" in
    api)        echo "viralefy-api" ;;
    front)      echo "viralefy-front" ;;
    backoffice) echo "viralefy-backoffice" ;;
    caddy)      echo "caddy" ;;
    grafana)    echo "grafana-server" ;;
    loki)       echo "loki" ;;
    tempo)      echo "tempo" ;;
    prom|prometheus) echo "prometheus" ;;
    alloy)      echo "alloy" ;;
    node)       echo "node-exporter" ;;
    obs)        echo "grafana-server loki tempo prometheus alloy node-exporter" ;;
    all|"")     echo "viralefy-api viralefy-front viralefy-backoffice caddy" ;;
    *) echo "viralefy-$1" ;;
  esac
}

units=$(mapper "${1:-all}")
shift 2>/dev/null || true
args=("$@")
[[ ${#args[@]} -eq 0 ]] && args=(-f -n 50)

# Constrói "-u u1 -u u2 ..." a partir da lista de units.
unit_args=()
for u in $units; do
  unit_args+=(-u "$u")
done

exec journalctl "${unit_args[@]}" "${args[@]}"
