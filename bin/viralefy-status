#!/usr/bin/env bash
# Visão rápida do estado do stack: systemd, portas, healthchecks.
set -uo pipefail

services=(viralefy-api viralefy-front viralefy-backoffice caddy \
          grafana-server loki tempo prometheus alloy node-exporter)

bold() { printf '\e[1m%s\e[0m\n' "$*"; }
ok()   { printf '  \e[32m✓\e[0m %s\n' "$*"; }
no()   { printf '  \e[31m✗\e[0m %s\n' "$*"; }
warn() { printf '  \e[33m!\e[0m %s\n' "$*"; }

bold "Serviços (systemd):"
for s in "${services[@]}"; do
  state="$(systemctl is-active "$s" 2>/dev/null || true)"
  enabled="$(systemctl is-enabled "$s" 2>/dev/null || true)"
  if [[ "$state" == "active" ]]; then
    ok "$s — active ($enabled)"
  else
    no "$s — $state ($enabled)"
  fi
done

bold "Portas:"
for p in 8080 3000 3001 80 443 3030 3100 3200 9090 9100 12345 4317 4318; do
  if ss -ltn 2>/dev/null | awk '{print $4}' | grep -qE "[:.]$p$"; then
    ok ":$p ouvindo"
  else
    no ":$p sem listener"
  fi
done

# Carrega DOMAIN_* do .env (read-only) — só pra mostrar URLs no status.
if [[ -r /etc/viralefy/.env ]]; then
  # shellcheck disable=SC1091
  set -a; source /etc/viralefy/.env; set +a
fi

bold "Health (loopback — apps):"
for u in \
  "API|http://127.0.0.1:8080/health" \
  "FRONT|http://127.0.0.1:3000" \
  "BACKOFFICE|http://127.0.0.1:3001/login"; do
  name="${u%%|*}"; url="${u##*|}"
  code="$(curl -s -o /dev/null -w '%{http_code}' --max-time 3 "$url" || echo "—")"
  if [[ "$code" == "200" ]]; then ok "$name $code"; else no "$name $code  $url"; fi
done

bold "Health (loopback — observabilidade):"
for u in \
  "Grafana|http://127.0.0.1:3030/api/health" \
  "Loki|http://127.0.0.1:3100/ready" \
  "Tempo|http://127.0.0.1:3200/ready" \
  "Prometheus|http://127.0.0.1:9090/-/ready" \
  "Alloy|http://127.0.0.1:12345/-/ready" \
  "node_exporter|http://127.0.0.1:9100/metrics"; do
  name="${u%%|*}"; url="${u##*|}"
  code="$(curl -s -o /dev/null -w '%{http_code}' --max-time 3 "$url" || echo "—")"
  if [[ "$code" == "200" ]]; then ok "$name $code"; else no "$name $code  $url"; fi
done

if [[ -n "${DOMAIN_API:-}" ]]; then
  bold "Health (público — via Caddy):"
  for u in \
    "API|https://${DOMAIN_API}/health" \
    "FRONT|https://${DOMAIN_FRONT}" \
    "BACKOFFICE|https://${DOMAIN_BACKOFFICE}/login"; do
    name="${u%%|*}"; url="${u##*|}"
    code="$(curl -sk -o /dev/null -w '%{http_code}' --max-time 5 "$url" 2>/dev/null || echo "—")"
    if [[ "$code" =~ ^[23] ]]; then ok "$name $code  $url"; else no "$name $code  $url"; fi
  done
fi

bold "Caddy:"
if [[ -f /etc/caddy/Caddyfile ]]; then
  if caddy validate --config /etc/caddy/Caddyfile --envfile /etc/caddy/viralefy.env >/dev/null 2>&1; then
    ok "Caddyfile válido"
  else
    no "Caddyfile inválido — sudo caddy validate --config /etc/caddy/Caddyfile --envfile /etc/caddy/viralefy.env"
  fi
fi

bold "PostgreSQL:"
if systemctl is-active postgresql >/dev/null 2>&1; then
  ok "postgresql active"
  if sudo -u postgres psql -tAc "SELECT 1 FROM pg_database WHERE datname='viralefy'" 2>/dev/null | grep -q 1; then
    ok "DB viralefy existe"
  else
    no "DB viralefy não existe"
  fi
else
  no "postgresql inativo"
fi
