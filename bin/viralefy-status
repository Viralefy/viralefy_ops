#!/usr/bin/env bash
# Visão rápida do estado do stack: systemd, portas, healthchecks.
set -uo pipefail

services=(viralefy-api viralefy-payments viralefy-sender \
          viralefy-front viralefy-backoffice caddy \
          grafana-server loki tempo prometheus alloy node-exporter)

bold() { printf '\e[1m%s\e[0m\n' "$*"; }
ok()   { printf '  \e[32m✓\e[0m %s\n' "$*"; }
no()   { printf '  \e[31m✗\e[0m %s\n' "$*"; }
warn() { printf '  \e[33m!\e[0m %s\n' "$*"; }

bold "Serviços (systemd):"
for s in "${services[@]}"; do
  state="$(systemctl is-active "$s" 2>/dev/null || true)"
  enabled="$(systemctl is-enabled "$s" 2>/dev/null || true)"
  if [[ "$state" == "active" ]]; then
    ok "$s — active ($enabled)"
  else
    no "$s — $state ($enabled)"
  fi
done

bold "Portas:"
for p in 8080 8081 8082 3000 3001 80 443 3030 3100 3200 9090 9100 12345 4317 4318; do
  if ss -ltn 2>/dev/null | awk '{print $4}' | grep -qE "[:.]$p$"; then
    ok ":$p ouvindo"
  else
    no ":$p sem listener"
  fi
done

# Carrega DOMAIN_* do .env (read-only) — só pra mostrar URLs no status.
if [[ -r /etc/viralefy/.env ]]; then
  # shellcheck disable=SC1091
  set -a; source /etc/viralefy/.env; set +a
fi

bold "Health (loopback — apps):"
for u in \
  "API|http://127.0.0.1:8080/health" \
  "FRONT|http://127.0.0.1:3000" \
  "BACKOFFICE|http://127.0.0.1:3001/login"; do
  name="${u%%|*}"; url="${u##*|}"
  code="$(curl -s -o /dev/null -w '%{http_code}' --max-time 3 "$url" || echo "—")"
  if [[ "$code" == "200" ]]; then ok "$name $code"; else no "$name $code  $url"; fi
done

bold "Microservices (loopback-only):"
# Cada microservice expõe systemd is-active + /internal/health. Esses
# endpoints só respondem em 127.0.0.1 — Caddy não os encaminha (exceto
# /v1/webhooks/* → payments). Falha aqui = api orfão; checar logs.
ms_port_payments="${PAYMENTS_PORT:-8081}"
ms_port_sender="${SENDER_PORT:-8082}"
for u in \
  "payments|$ms_port_payments" \
  "sender|$ms_port_sender"; do
  name="${u%%|*}"; port="${u##*|}"
  state="$(systemctl is-active "viralefy-$name" 2>/dev/null || true)"
  if [[ "$state" == "active" ]]; then ok "viralefy-$name systemd active"
  else no "viralefy-$name systemd $state"; fi
  url="http://127.0.0.1:$port/internal/health"
  code="$(curl -s -o /dev/null -w '%{http_code}' --max-time 3 "$url" || echo "—")"
  if [[ "$code" == "200" ]]; then ok "viralefy-$name health $code  $url"
  else no "viralefy-$name health $code  $url"; fi
done

bold "Health (loopback — observabilidade):"
for u in \
  "Grafana|http://127.0.0.1:3030/api/health" \
  "Loki|http://127.0.0.1:3100/ready" \
  "Tempo|http://127.0.0.1:3200/ready" \
  "Prometheus|http://127.0.0.1:9090/-/ready" \
  "Alloy|http://127.0.0.1:12345/-/ready" \
  "node_exporter|http://127.0.0.1:9100/metrics"; do
  name="${u%%|*}"; url="${u##*|}"
  code="$(curl -s -o /dev/null -w '%{http_code}' --max-time 3 "$url" || echo "—")"
  if [[ "$code" == "200" ]]; then ok "$name $code"; else no "$name $code  $url"; fi
done

if [[ -n "${DOMAIN_API:-}" ]]; then
  bold "Health (público — via Caddy):"
  for u in \
    "API|https://${DOMAIN_API}/health" \
    "FRONT|https://${DOMAIN_FRONT}" \
    "BACKOFFICE|https://${DOMAIN_BACKOFFICE}/login"; do
    name="${u%%|*}"; url="${u##*|}"
    code="$(curl -sk -o /dev/null -w '%{http_code}' --max-time 5 "$url" 2>/dev/null || echo "—")"
    if [[ "$code" =~ ^[23] ]]; then ok "$name $code  $url"; else no "$name $code  $url"; fi
  done
fi

bold "Caddy:"
if [[ -f /etc/caddy/Caddyfile ]]; then
  if caddy validate --config /etc/caddy/Caddyfile --envfile /etc/caddy/viralefy.env >/dev/null 2>&1; then
    ok "Caddyfile válido"
  else
    no "Caddyfile inválido — sudo caddy validate --config /etc/caddy/Caddyfile --envfile /etc/caddy/viralefy.env"
  fi
fi

bold "PostgreSQL:"
if systemctl is-active postgresql >/dev/null 2>&1; then
  ok "postgresql active"
  if sudo -u postgres psql -tAc "SELECT 1 FROM pg_database WHERE datname='viralefy'" 2>/dev/null | grep -q 1; then
    ok "DB viralefy existe"
  else
    no "DB viralefy não existe"
  fi
else
  no "postgresql inativo"
fi

bold "Object storage (MinIO):"
if docker inspect --format='{{.State.Health.Status}}' viralefy-storage 2>/dev/null | grep -q healthy; then
  ok "viralefy-storage container healthy"
  if curl -fsS -o /dev/null --max-time 3 "http://127.0.0.1:9000/minio/health/ready" 2>/dev/null; then
    ok "MinIO S3 endpoint ready (127.0.0.1:9000)"
  else
    warn "MinIO ready endpoint não respondeu"
  fi
elif command -v docker >/dev/null 2>&1; then
  no "viralefy-storage container ausente/unhealthy — rodar install_storage"
else
  warn "docker ausente — storage não instalado"
fi

bold "Sentry (error reporting):"
# DSN_API: server-only. DSN_FRONT/BACKOFFICE: NEXT_PUBLIC_ (visíveis no bundle).
# Sentry SDK é no-op quando DSN vazio — alerta o operador quando esquecer.
sentry_state=ok
for var in SENTRY_DSN NEXT_PUBLIC_SENTRY_DSN; do
  val="${!var:-}"
  if [[ -z "$val" ]]; then
    warn "$var não setado — Sentry $var em modo no-op"
    sentry_state=warn
  fi
done
if [[ "$sentry_state" == "ok" ]]; then
  ok "DSNs presentes — Sentry SDK ativo nos 3 services"
  if [[ -z "${SENTRY_AUTH_TOKEN:-}" ]]; then
    warn "SENTRY_AUTH_TOKEN ausente — stack traces sem source map (ofuscados)"
  else
    ok "SENTRY_AUTH_TOKEN presente — source map upload no CI configurável"
  fi
fi
