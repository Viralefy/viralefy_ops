#!/usr/bin/env bash
# viralefy-smoke — verificação leve pós-deploy dos 3 services + endpoints
# chave da API. Rodar DEPOIS de `viralefy-update` (o update já roda o
# healthcheck loopback básico; este script complementa com endpoints reais
# do contrato HTTP da Fase 8).
#
# Exit 1 em qualquer falha → integração com systemd OnFailure e CI fica
# trivial.
#
# Critérios (Phase 8 §10):
#   1. viralefy-api    GET 127.0.0.1:8080/health           → 200
#   2. viralefy-payments GET 127.0.0.1:8081/internal/health → 200
#   3. viralefy-sender   GET 127.0.0.1:8082/internal/health → 200
#   4. GET /v1/plans (público, sem auth)                   → 200 + JSON array
#   5. POST /v1/me/2fa/status (sem Bearer)                 → 401 (auth gate ok)
#   6. POST /v1/checkout COM payload real + tracking       → 201 + order_id +
#      payment_url. Regression test pra Coraza FP em tracking.landing_url
#      (incidente 2026-06-10): CRS PL2 disparava 942100 (SQLi) na URL legítima
#      do landing. Smoke replica EXATAMENTE o payload do CheckoutModal pra
#      prevenir regressão silenciosa em mudanças de exclusion/ruleset.
#      Cleanup dos test users (@viralefy.test) é feito pelo
#      viralefy-test-cleanup.timer (hourly).
#
# Sem deps externas. Usa só curl + python3 (stdlib) — disponíveis em
# qualquer host Debian.
#
# ─── HEALTH ENDPOINT MAPPING (PHASE-10 unification 2026-06-11) ───────────
# Migração pra /health unificado em 2026-06-11; cada service ganhou um
# alias `/health` que reusa o handler existente. Os paths legados continuam
# respondendo (backward compat — TX retention pra Uptime Robot, dashboards
# antigos e systemd probes que ainda chamam o path original).
#
#   svc                  port   path canônico  paths aceitos (alias + legacy)
#   ──────────────────────────────────────────────────────────────────────────
#   viralefy-api         8080   /health        /health                       (legacy nativo)
#   viralefy-core        8084   /health        /health                       (já era /health)
#   viralefy-payments    8081   /health        /health  + /internal/health
#   viralefy-sender      8082   /health        /health  + /internal/health
#   viralefy-auth        8083   /health        /health  + /internal/v1/health
#   viralefy-dispatcher  8090   /health        /health  + /_health
#
# Smoke usa o path canônico `/health` em todos os services. Entries legacy
# permanecem nos comentários acima e nos próprios services pra TX retention
# durante o rollout — não removê-los até PHASE-11 (410 nos legados).
# ─────────────────────────────────────────────────────────────────────────

set -euo pipefail
IFS=$'\n\t'

# PHASE-9 (2026-06-10): legacy api parada em soak. Smoke usa dispatcher
# (:8090) como ponto único, exatamente como Caddy → upstream em prod.
API_HOST="${VIRALEFY_API_HOST:-127.0.0.1:8090}"
PAY_HOST="${VIRALEFY_PAY_HOST:-127.0.0.1:8081}"
SND_HOST="${VIRALEFY_SND_HOST:-127.0.0.1:8082}"
# PHASE-17 (2026-06-14): novos checks de SSR/i18n/cookie batem no Next direto
# (loopback 3000) ou via Caddy externo (FRONT_URL). Default: localhost SSR,
# que é o que o systemd-deploy expõe pro smoke pós-update. Override em CI.
FRONT_HOST="${VIRALEFY_FRONT_HOST:-127.0.0.1:3000}"

# Self-check toggle. Quando = 1, o último passo do smoke executa uma asserção
# que SEMPRE falha (espera 404 em /v1/plans que retorna 200) pra provar que o
# runner de fato reporta erro. Mantemos OFF por padrão (smoke verde em prod);
# ligamos em verificação periódica da pipeline de smoke (manual/cron mensal).
# Padrão skill §22: smoke que nunca falha está cego — esse hook prova que não.
VIRALEFY_SMOKE_SELFCHECK="${VIRALEFY_SMOKE_SELFCHECK:-0}"

FAIL=0
ok()   { echo "  ok    $*"; }
bad()  { echo "  FAIL  $*"; FAIL=1; }
note() { echo "[smoke] $*"; }

# Curl helper: imprime status code; corpo em $TMPBODY.
TMPBODY="$(mktemp)"
trap 'rm -f "$TMPBODY"' EXIT

http_code() {
  local method="$1" url="$2"
  # Quando curl falha (host down, refused), %{http_code} pode imprimir "000"
  # E O `|| echo "000"` adiciona OUTRO "000" → resultado "000000". Fix:
  # capturar o output e normalizar pra exatamente 3 chars.
  local out
  out=$(curl -sS -o "$TMPBODY" -w '%{http_code}' -X "$method" \
       --max-time 5 --connect-timeout 2 "$url" 2>/dev/null) || out="000"
  # Pega só os 3 últimos dígitos (caso o erro tenha duplicado).
  echo "${out: -3}"
}

# ─── 1-3. Healths dos services ──────────────────────────────────────────
# PHASE-10 (2026-06-11): paths unificados em /health. Endpoints legacy
# continuam respondendo nos services, mas o smoke valida o caminho canônico.
note "health dos services (/health unificado — PHASE-10)"
for entry in \
    "dispatcher http://$API_HOST/health" \
    "pay        http://$PAY_HOST/health" \
    "sender     http://$SND_HOST/health"; do
  svc="${entry%% *}"
  url="${entry##* }"
  code="$(http_code GET "$url")"
  if [[ "$code" == "200" ]]; then
    ok "$svc $url → 200"
  else
    bad "$svc $url → $code (esperado 200)"
  fi
done

# ─── Upstream services (core + auth atrás do dispatcher) ──────────────────
# Validamos loopback direto pra detectar falha de upstream que o dispatcher
# possa estar mascarando.
note "upstream services (core + auth direto)"
for entry in \
    "core       http://${VIRALEFY_CORE_HOST:-127.0.0.1:8084}/health" \
    "auth       http://${VIRALEFY_AUTH_HOST:-127.0.0.1:8083}/health"; do
  svc="${entry%% *}"
  url="${entry##* }"
  code="$(http_code GET "$url")"
  if [[ "$code" == "200" ]]; then
    ok "$svc $url → 200"
  elif [[ "$code" == "000" ]]; then
    echo "  skip  $svc não responde (PHASE-9 desabilitado?)"
  else
    bad "$svc $url → $code (esperado 200 ou 000)"
  fi
done

# ─── 4. GET /v1/plans público (sem auth) ──────────────────────────────────
note "endpoint público /v1/plans"
code="$(http_code GET "http://$API_HOST/v1/plans")"
if [[ "$code" == "200" ]]; then
  # Verifica que é JSON. API envelopa em {"data": ...} desde Fase 4.
  # Aceita também array raw (compat legado).
  first_char="$(head -c 1 "$TMPBODY")"
  if [[ "$first_char" == "{" || "$first_char" == "[" ]]; then
    ok "/v1/plans → 200 + JSON"
  else
    bad "/v1/plans → 200 mas corpo não parece JSON ($(head -c 80 "$TMPBODY"))"
  fi
else
  bad "/v1/plans → $code (esperado 200)"
fi

# ─── 5. POST /v1/me/2fa/status sem Bearer → 401 ───────────────────────────
note "auth gate em /v1/me/2fa/status (sem Bearer)"
code="$(http_code POST "http://$API_HOST/v1/me/2fa/status")"
if [[ "$code" == "401" ]]; then
  ok "/v1/me/2fa/status (sem token) → 401"
else
  bad "/v1/me/2fa/status (sem token) → $code (esperado 401)"
fi

# ─── 6. Checkout E2E com tracking real (regression test Coraza FP) ────────
# Replica EXATAMENTE o payload que o CheckoutModal manda em prod, incluindo
# tracking.landing_url no formato `https://www.viralefy.com/<lang>/<slug>`.
# Esse formato é o que disparava Coraza CRS 942100 (SQLi) em 2026-06-10:
# o `-` no slug + protocolo + path multi-segment confundia o detector. Smoke
# precisa cobrir esse vetor pra qualquer mudança futura em exclusions/ruleset
# falhar AQUI antes de chegar ao usuário real.
#
# Fail-soft: se /v1/plans ou /payment-methods estiverem temporariamente
# indisponíveis, marcamos bad mas seguimos pro resultado final. Test users
# usam pattern `*@viralefy.test` — cleanup automático via
# viralefy-test-cleanup.timer (hourly).
note "checkout E2E com tracking real (regression Coraza FP 2026-06-10)"

# Re-fetch /v1/plans (TMPBODY foi sobrescrito pelos checks anteriores).
code="$(http_code GET "http://$API_HOST/v1/plans")"
PLAN_ID=""
if [[ "$code" == "200" ]]; then
  PLAN_ID=$(python3 -c "
import json,sys
try:
    d=json.load(open('$TMPBODY'))
    arr=d.get('data', d) if isinstance(d, dict) else d
    print(arr[0].get('id','') if arr else '')
except Exception:
    print('')
" 2>/dev/null)
fi

if [[ -z "$PLAN_ID" ]]; then
  bad "checkout: não consegui extrair plan_id de /v1/plans"
else
  # Busca gateway_id (qualquer gateway active serve — preferencialmente
  # crypto/Heleket pra evitar deps externas no test).
  code="$(http_code GET "http://$API_HOST/v1/plans/$PLAN_ID/payment-methods")"
  if [[ "$code" != "200" ]]; then
    bad "checkout: /v1/plans/$PLAN_ID/payment-methods → $code (esperado 200)"
  else
    GW_ID=$(python3 -c "
import json,sys
try:
    d=json.load(open('$TMPBODY'))
    arr=d.get('data', d) if isinstance(d, dict) else d
    # primeiro gateway com gateway_id presente
    for m in (arr or []):
        gid=m.get('gateway_id','')
        if gid:
            print(gid); break
    else:
        print('')
except Exception:
    print('')
" 2>/dev/null)
    if [[ -z "$GW_ID" ]]; then
      bad "checkout: não consegui extrair gateway_id de payment-methods"
    else
      # Payload réplica do CheckoutModal — landing_url no formato que
      # disparou o FP (slug com hyphen + path /<lang>/<service>).
      STAMP=$(date +%s%N)
      EMAIL="smoke-${STAMP}@viralefy.test"
      PAYLOAD=$(cat <<JSON
{
  "plan_id": "$PLAN_ID",
  "email": "$EMAIL",
  "name": "Smoke Test",
  "display_currency": "USD",
  "payment_method": "gateway",
  "gateway_id": "$GW_ID",
  "pay_currency": "USDT",
  "new_profile": {
    "platform": "instagram",
    "handle": "smoketest",
    "display_name": "Smoke"
  },
  "tracking": {
    "landing_url": "https://www.viralefy.com/us/instagram-followers",
    "referrer": "https://google.com/",
    "utm_source": "google",
    "fbclid": "smoke-fbclid"
  },
  "country": "us",
  "target_country": "us"
}
JSON
)
      code=$(curl -sS -o "$TMPBODY" -w '%{http_code}' \
        --max-time 10 --connect-timeout 2 \
        -X POST -H 'Content-Type: application/json' \
        -H "Idempotency-Key: smoke-$STAMP" \
        -d "$PAYLOAD" \
        "http://$API_HOST/v1/checkout" 2>/dev/null) || code="000"
      code="${code: -3}"

      if [[ "$code" == "201" ]]; then
        # Valida envelope: precisa de order_id + payment_url pra ser E2E real.
        # Coraza FP retornaria 403 sem JSON, ou JSON sem esses campos.
        ORDER_ID=$(python3 -c "
import json
try:
    d=json.load(open('$TMPBODY'))
    print((d.get('data') or d).get('order_id',''))
except Exception:
    print('')
" 2>/dev/null)
        PAY_URL=$(python3 -c "
import json
try:
    d=json.load(open('$TMPBODY'))
    print((d.get('data') or d).get('payment_url',''))
except Exception:
    print('')
" 2>/dev/null)
        if [[ -n "$ORDER_ID" ]] && [[ -n "$PAY_URL" ]]; then
          ok "checkout E2E → 201 + order_id + payment_url"
        else
          bad "checkout E2E → 201 mas faltam fields (order_id='$ORDER_ID' payment_url='$PAY_URL')"
        fi
      else
        bad "checkout E2E → $code (esperado 201)"
        echo "    Body: $(head -c 200 "$TMPBODY")"
      fi
    fi
  fi
fi

# ─── 7-11. SSR/i18n/cookie/SEO smoke (rounds 13-17 regressions) ───────────
# Esses checks batem na superfície do front (Next SSR). Validam o shape REAL
# do HTML emitido — não só status 200 — para os fixes dos últimos rounds:
#   - Round 13: i18n SSR completo (PT em /pricing, RTL em AR).
#   - Round 14: JSON-LD consolidado num único <script> via @graph (BUG-191).
#   - Round 15: header único no layout (BUG-204), sem duplicação por nested layout.
#   - Round 16: cookies SSR (vf_theme) lidos no server e refletidos em data-theme.
#
# Fail-soft: se o front-host não responde (rollout em progresso, próprio Next
# subindo), marcamos skip e seguimos — não derrubamos o smoke todo por isso.
note "SSR/i18n/cookie smoke (rounds 13-17 regressions)"

http_body() {
  # Usage: http_body <method> <url> [extra curl args...]
  # Imprime o status code; corpo fica em $TMPBODY.
  local method="$1" url="$2"; shift 2
  local out
  out=$(curl -sS -o "$TMPBODY" -w '%{http_code}' -X "$method" \
       --max-time 5 --connect-timeout 2 "$@" "$url" 2>/dev/null) || out="000"
  echo "${out: -3}"
}

# 7. i18n PT em /pricing (Accept-Language: pt-BR) → <title> com "Preço" ou
#    "Preços" (Next emite a string traduzida via dictionary PT).
code="$(http_body GET "http://$FRONT_HOST/pricing" -H 'Accept-Language: pt-BR,pt;q=0.9')"
if [[ "$code" == "000" ]]; then
  echo "  skip  front $FRONT_HOST/pricing não responde (rollout?)"
elif [[ "$code" == "200" ]]; then
  # Title case-insensitive, aceita "Preços" ou "Preço" (variações).
  if grep -qiE '<title>[^<]*pre[çc]o' "$TMPBODY"; then
    ok "/pricing pt-BR → <title> traduzido (BUG i18n round 13)"
  else
    bad "/pricing pt-BR → 200 mas <title> não tem 'Preço/Preços' ($(grep -oE '<title>[^<]*' "$TMPBODY" | head -1))"
  fi
else
  bad "/pricing pt-BR → $code (esperado 200)"
fi

# 8. i18n RTL em /pricing (Accept-Language: ar-SA) → <html dir="rtl">.
code="$(http_body GET "http://$FRONT_HOST/pricing" -H 'Accept-Language: ar-SA,ar;q=0.9')"
if [[ "$code" == "000" ]]; then
  echo "  skip  front $FRONT_HOST/pricing (ar) não responde"
elif [[ "$code" == "200" ]]; then
  if grep -qE '<html[^>]*dir="rtl"' "$TMPBODY"; then
    ok "/pricing ar-SA → <html dir=\"rtl\"> (BUG i18n round 13)"
  else
    bad "/pricing ar-SA → 200 mas <html> não tem dir=rtl ($(grep -oE '<html[^>]*' "$TMPBODY" | head -1))"
  fi
else
  bad "/pricing ar-SA → $code (esperado 200)"
fi

# 9. JSON-LD count na home: exatamente UM <script type="application/ld+json">
#    (BUG-191 round 14: antes emitia N scripts duplicados; agora consolidado
#    em @graph).
code="$(http_body GET "http://$FRONT_HOST/")"
if [[ "$code" == "000" ]]; then
  echo "  skip  front $FRONT_HOST/ não responde"
elif [[ "$code" == "200" ]]; then
  cnt=$(grep -oE 'application/ld\+json' "$TMPBODY" | wc -l)
  if [[ "$cnt" == "1" ]]; then
    ok "/ → exatamente 1 bloco JSON-LD (@graph, BUG-191)"
  else
    bad "/ → $cnt blocos JSON-LD (esperado 1, regressão @graph BUG-191)"
  fi
else
  bad "/ → $code (esperado 200)"
fi

# 10. Header único na home (BUG-204 round 15): exatamente UM <header em todo
#     o HTML emitido. Layouts aninhados não devem duplicar.
if [[ "$code" == "200" ]]; then
  hdr=$(grep -oE '<header[ >]' "$TMPBODY" | wc -l)
  if [[ "$hdr" == "1" ]]; then
    ok "/ → exatamente 1 <header> (BUG-204 sem duplicação)"
  else
    bad "/ → $hdr <header> tags (esperado 1, regressão BUG-204)"
  fi
fi

# 11. Cookies SSR (round 16): vf_theme=dark deve aparecer como data-theme="dark"
#     no <html> emitido. Prova que o server lê o cookie e propaga pro markup
#     (não fica esperando hidratação client-side, evitando FOUC).
code="$(http_body GET "http://$FRONT_HOST/" -b 'vf_theme=dark')"
if [[ "$code" == "000" ]]; then
  echo "  skip  front $FRONT_HOST/ (cookie) não responde"
elif [[ "$code" == "200" ]]; then
  if grep -qE '<html[^>]*data-theme="dark"' "$TMPBODY"; then
    ok "/ vf_theme=dark cookie → data-theme=\"dark\" no SSR (round 16)"
  else
    bad "/ vf_theme=dark cookie → SSR não refletiu data-theme=dark ($(grep -oE '<html[^>]*' "$TMPBODY" | head -1))"
  fi
else
  bad "/ vf_theme=dark → $code (esperado 200)"
fi

# 12. Self-check (padrão skill §22): asserção que SEMPRE falha — espera 404
#     em /v1/plans que sabemos retornar 200. Quando VIRALEFY_SMOKE_SELFCHECK=1
#     forçamos FAIL pra provar que o reporter detecta erro. Sem isso o smoke
#     fica cego (sempre verde mesmo se assertions estiverem quebradas).
#     OFF por padrão; rodar manualmente com:
#         VIRALEFY_SMOKE_SELFCHECK=1 viralefy-smoke
#     Esperado: exit 1, com FAIL na linha "[self-check]". Cron mensal opcional.
if [[ "$VIRALEFY_SMOKE_SELFCHECK" == "1" ]]; then
  note "[self-check] forçando FAIL conhecido (espera 404 em /v1/plans)"
  code="$(http_code GET "http://$API_HOST/v1/plans")"
  if [[ "$code" == "404" ]]; then
    ok "[self-check] /v1/plans → 404 (??? deveria ter sido 200 — investigar)"
  else
    bad "[self-check] /v1/plans → $code (esperado 404 PROPOSITAL — reporter OK)"
  fi
fi

# ─── Resultado ────────────────────────────────────────────────────────────
echo
if [[ $FAIL -eq 0 ]]; then
  note "smoke OK"
  exit 0
fi
note "smoke FALHOU"
exit 1
