#!/usr/bin/env bash
# viralefy-backup — dump compactado do Postgres + retenção.
#
# Roda como root via systemd timer. Lê DATABASE_URL de /etc/viralefy/.env
# pra autenticar (pg_dump aceita URI completa). Saída: arquivo gzip em
# /var/backups/viralefy/dump-<UTC-ISO>.sql.gz.
#
# Retenção:
#   - 7 dailies (últimos 7 dias)
#   - 4 weeklies (domingo é o âncora)
#   - 6 monthlies (dia 1)
# Qualquer arquivo fora dessas categorias é apagado.
#
# Métrica Prometheus (textfile collector, node_exporter):
#   /var/lib/prometheus/node_exporter/viralefy_backup.prom
#     viralefy_backup_last_success_timestamp <epoch>
#     viralefy_backup_last_size_bytes <bytes>
#     viralefy_backup_count_total <int>
# Alerta sugerido: time() - viralefy_backup_last_success_timestamp > 36*3600

set -euo pipefail
IFS=$'\n\t'

ENV_FILE=/etc/viralefy/.env
BACKUP_DIR=/var/backups/viralefy
TEXTFILE_DIR=/var/lib/prometheus/node_exporter
TEXTFILE=$TEXTFILE_DIR/viralefy_backup.prom

[[ $EUID -eq 0 ]] || { echo "Precisa rodar como root."; exit 1; }
[[ -r $ENV_FILE ]] || { echo "ENV file $ENV_FILE inacessível."; exit 1; }

# shellcheck disable=SC1090
set -a; source "$ENV_FILE"; set +a

if [[ -z "${DATABASE_URL:-}" ]]; then
  echo "DATABASE_URL ausente em $ENV_FILE."; exit 1
fi

install -d -m 0700 -o root -g root "$BACKUP_DIR"
install -d -m 0755 -o root -g root "$TEXTFILE_DIR"

TS="$(date -u +%Y%m%dT%H%M%SZ)"
OUT="$BACKUP_DIR/dump-$TS.sql.gz"
TMP="$OUT.tmp"

echo "[backup] dump → $OUT"
pg_dump --no-owner --no-acl --format=plain "$DATABASE_URL" | gzip -9 > "$TMP"
mv -f "$TMP" "$OUT"
chmod 0600 "$OUT"

# ---------- retenção ----------
# Mantém: 7 dailies (últimos 7 calendários), 4 weeklies (domingos), 6 monthlies (dia 1).
# Implementação: lista todos os dumps, classifica cada um e apaga o que não cabe.
echo "[backup] aplicando retenção"
cd "$BACKUP_DIR"
mapfile -t ALL < <(ls -1 dump-*.sql.gz 2>/dev/null | sort -r)

declare -A KEEP=()

# 7 dailies mais recentes
i=0
for f in "${ALL[@]}"; do
  KEEP[$f]=1
  ((++i))
  [[ $i -ge 7 ]] && break
done

# 4 weeklies (1 por domingo, últimos 4)
sundays_kept=0
for f in "${ALL[@]}"; do
  # extrai YYYYMMDD do nome dump-YYYYMMDDTHHMMSSZ.sql.gz
  d="${f#dump-}"
  d="${d:0:8}"
  dow=$(date -d "$d" +%u 2>/dev/null || echo "")
  if [[ "$dow" == "7" ]]; then
    KEEP[$f]=1
    ((++sundays_kept))
    [[ $sundays_kept -ge 4 ]] && break
  fi
done

# 6 monthlies (1 por dia-1, últimos 6)
firsts_kept=0
for f in "${ALL[@]}"; do
  d="${f#dump-}"
  d="${d:0:8}"
  dom="${d:6:2}"
  if [[ "$dom" == "01" ]]; then
    KEEP[$f]=1
    ((++firsts_kept))
    [[ $firsts_kept -ge 6 ]] && break
  fi
done

deleted=0
for f in "${ALL[@]}"; do
  if [[ -z "${KEEP[$f]:-}" ]]; then
    rm -f "$f"
    ((++deleted))
  fi
done
echo "[backup] retenção: ${#KEEP[@]} mantidos, $deleted removidos"

# ---------- métricas ----------
SIZE=$(stat -c%s "$OUT")
NOW=$(date -u +%s)
COUNT=$(ls -1 dump-*.sql.gz 2>/dev/null | wc -l)

cat > "$TEXTFILE.tmp" <<METRICS
# HELP viralefy_backup_last_success_timestamp Unix epoch do último backup bem-sucedido.
# TYPE viralefy_backup_last_success_timestamp gauge
viralefy_backup_last_success_timestamp $NOW
# HELP viralefy_backup_last_size_bytes Tamanho do último dump em bytes.
# TYPE viralefy_backup_last_size_bytes gauge
viralefy_backup_last_size_bytes $SIZE
# HELP viralefy_backup_count_total Quantidade de dumps mantidos.
# TYPE viralefy_backup_count_total gauge
viralefy_backup_count_total $COUNT
METRICS
mv -f "$TEXTFILE.tmp" "$TEXTFILE"
chmod 0644 "$TEXTFILE"

echo "[backup] ok size=$SIZE bytes count=$COUNT"
