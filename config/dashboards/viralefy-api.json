      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "viralefy-prometheus" },
          "expr": "sum by (provider, status) (rate(gateway_callbacks_total{job=\"viralefy-api\"}[5m]))",
          "legendFormat": "{{provider}} / {{status}}",
          "refId": "A"
        }
