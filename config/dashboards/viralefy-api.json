      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "viralefy-prometheus" },
          "expr": "sum by (query_type) (rate(db_query_duration_seconds_count{job=\"viralefy-api\"}[1m]))",
          "legendFormat": "{{query_type}}",
          "refId": "A"
        }
      ],
      "title": "DB queries/sec",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "viralefy-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
