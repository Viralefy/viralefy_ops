# Viralefy — Caddy reverse proxy + TLS automático.
# Variáveis vêm de /etc/caddy/viralefy.env (DOMAIN_*, CADDY_EMAIL).
# Apps escutam só em 127.0.0.1; Caddy é a única superfície pública.

{
	email {$CADDY_EMAIL}
	servers {
		trusted_proxies static private_ranges
	}
	# Ordem de directives — coraza_waf precisa rodar ANTES do reverse_proxy.
	# Sem isso, requests passam pro upstream antes do WAF inspecionar.
	order coraza_waf first
}

# ---------------- apex → www (canônico flipped) ---------------- #
# A loja é canônica em www.viralefy.com. Apex viralefy.com redireciona 301
# preservando path/query — bookmarks e backlinks históricos continuam vivos.
#
# IMPORTANTE: capturamos http:// e https:// explicitamente pra evitar a hop
# intermediária do Caddy global handler (que faria http://apex → https://apex
# antes do redir). Cadeia HTTP→HTTPS→www = 2 hops e Ahrefs flagga como
# "redirect chain". Com os 2 blocos abaixo, http://apex → https://www em UM
# único 301, e https://apex → https://www em UM único 301.
http://{$DOMAIN_FRONT} {
	redir https://www.{$DOMAIN_FRONT}{uri} 301
}
{$DOMAIN_FRONT} {
	redir https://www.{$DOMAIN_FRONT}{uri} 301
}

# ---------------- Loja (canônica em www) ---------------- #
www.{$DOMAIN_FRONT} {
	encode zstd gzip

	header {
		# HSTS (1 ano, subdomínios, preload).
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "interest-cohort=(), browsing-topics=()"
		Cross-Origin-Opener-Policy "same-origin"
		# X-Robots-Tag explícito (default seria indexar tudo, mas Ahrefs flagga
		# como "Ausente" quando não tem header). /account /tickets /login etc.
		# já bloqueados por robots.txt + meta robots noindex no Next.js, então
		# não duplicamos via X-Robots-Tag aqui (override no Caddy não tava
		# pegando consistentemente).
		X-Robots-Tag "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
		-Server
		-X-Powered-By
	}

	reverse_proxy 127.0.0.1:3000 {
		header_up X-Real-IP {http.request.remote.host}
	}

	log {
		output stderr
		format json
	}
}

# ---------------- Backoffice ---------------- #
{$DOMAIN_BACKOFFICE} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Content-Security-Policy "frame-ancestors 'none'"
		Permissions-Policy "interest-cohort=(), browsing-topics=()"
		Cross-Origin-Opener-Policy "same-origin"
		-Server
		-X-Powered-By
	}

	reverse_proxy 127.0.0.1:3001 {
		header_up X-Real-IP {http.request.remote.host}
	}

	log {
		output stderr
		format json
	}
}

# ---------------- Observability (Grafana) ---------------- #
{$DOMAIN_OBS} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Cross-Origin-Opener-Policy "same-origin"
		-Server
		-X-Powered-By
	}

	# Grafana escuta em 127.0.0.1:3030 (3000 já é do viralefy-front).
	reverse_proxy 127.0.0.1:3030 {
		header_up X-Real-IP {http.request.remote.host}
	}

	log {
		output stderr
		format json
	}
}

# ---------------- API ---------------- #
{$DOMAIN_API} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin"
		Cross-Origin-Opener-Policy "same-origin"
		-Server
		-X-Powered-By
	}

	# ---- Coraza WAF — OWASP CRS 4.x ---- #
	# PHASE-9 §3.1. Defesa em profundidade contra XSS, SQLi, path traversal,
	# command injection antes de qualquer roteamento pros services Go.
	#
	# Modo inicial: DetectionOnly (audit em /var/log/caddy-waf/audit.log,
	# não bloqueia ainda). Janela mínima de 14 dias coletando false positives
	# antes de mudar pra Block. Tuning de exceções fica em CRS_EXCLUSION_*
	# config no crs-setup.conf.
	#
	# Limites cobertos pelo CRS (NÃO substitui validação de domínio):
	#   - SQLi (rules 942xxx)
	#   - XSS (rules 941xxx)
	#   - LFI/path traversal (rules 930xxx, 932xxx)
	#   - RCE (rules 932xxx)
	#   - HTTP protocol violations (920xxx)
	# NÃO cobre IDOR/BOLA, mass-assignment, business logic — esses ficam
	# em viralefy_core/middlewares (vide PHASE-9-ARCHITECTURE §3.2).
	coraza_waf {
		directives `
			Include /etc/caddy/coraza/coraza.conf
			Include /etc/caddy/coraza/crs/crs-setup.conf
			Include /etc/caddy/coraza/crs/rules/*.conf
		`
	}

	# /health e /ready continuam públicos (necessários p/ load balancers).
	# CORS é responsabilidade da API (CORS_ORIGINS em .env).

	# ---- Defesa em profundidade: /internal/* nunca pode vazar pra fora ---- #
	# Os endpoints /internal/v1/* são callbacks loopback entre microservices
	# (PHASE-8). Já são gateados por X-Internal-Token, mas: 1) o token vaza se
	# logamos request body em erro, 2) qualquer probe externo conseguia ver
	# 401 + trace_id (info disclosure), 3) bruteforce era teoricamente possível.
	# Bloqueio na borda fecha as 3 brechas. Retornamos 404 (não 403) pra não
	# revelar que a rota existe.
	@internal path /internal/*
	handle @internal {
		respond "Not Found" 404 {
			close
		}
	}

	# ---- Webhooks de pagamento → viralefy_payments (127.0.0.1:8081) ---- #
	# Stripe/Heleket/Woovi/AbacatePay entregam em api.viralefy.com/v1/webhooks/
	# <provider>; o microservice valida assinatura + idempotência e chama o
	# callback interno na API monolítica.
	#
	# IMPORTANTE: usamos `handle` (não `handle_path`) + rewrite pra preservar
	# o path e PREPENDER `/internal`. Assim a rota no payments é
	# `POST /internal/v1/webhooks/<provider>` — case com o router de lá.
	handle /v1/webhooks/stripe* {
		rewrite * /internal{path}
		reverse_proxy 127.0.0.1:8081 {
			header_up X-Real-IP {http.request.remote.host}
			header_up X-Forwarded-Webhook "stripe"
		}
	}
	handle /v1/webhooks/heleket* {
		rewrite * /internal{path}
		reverse_proxy 127.0.0.1:8081 {
			header_up X-Real-IP {http.request.remote.host}
			header_up X-Forwarded-Webhook "heleket"
		}
	}
	handle /v1/webhooks/woovi* {
		rewrite * /internal{path}
		reverse_proxy 127.0.0.1:8081 {
			header_up X-Real-IP {http.request.remote.host}
			header_up X-Forwarded-Webhook "woovi"
		}
	}
	handle /v1/webhooks/abacatepay* {
		rewrite * /internal{path}
		reverse_proxy 127.0.0.1:8081 {
			header_up X-Real-IP {http.request.remote.host}
			header_up X-Forwarded-Webhook "abacatepay"
		}
	}

	# ---- PHASE-9 Bucket 1 — public read-only via dispatcher (:8090) ---- #
	# Strangler cutover por bucket: rotas idempotentes e públicas (sem auth)
	# vão pra Rust dispatcher → routes pra viralefy_core (:8084) ou viralefy_auth
	# (:8083, no caso de JWKS). Parity 100% validada antes do swap (status+body
	# identical legacy vs dispatcher pra todos os paths abaixo).
	#
	# Rollback: comentar este bloco e reload Caddy — volta pro :8080 monolito.
	# Bucket 2 (auth user), 3 (admin), 4 (checkout) seguem em sessões futuras.
	handle /v1/plans* {
		reverse_proxy 127.0.0.1:8090 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}
	handle /v1/categories* {
		reverse_proxy 127.0.0.1:8090 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}
	handle /v1/currencies* {
		reverse_proxy 127.0.0.1:8090 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}
	handle /v1/status* {
		reverse_proxy 127.0.0.1:8090 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}
	handle /v1/country-ppp* {
		reverse_proxy 127.0.0.1:8090 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}
	handle /v1/tax-rates* {
		reverse_proxy 127.0.0.1:8090 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}
	handle /.well-known/jwks.json {
		reverse_proxy 127.0.0.1:8090 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}

	# ---- PHASE-9 Bucket 2 (a+b) — área logada do usuário via dispatcher ---- #
	# /v1/me/* (GET + POST + PUT + DELETE) — 38 rotas. Parity pré-swap: 401
	# sem Bearer em ambos legacy e dispatcher, body shape idêntico (só
	# trace_id varia). Dual-sign já existe em legacy → tokens RS256 emitidos
	# por auth/core/legacy são interchangeable, sem auth chain break.
	# DB compartilhado → mutações idempotentes mesmo se path alternar.
	handle /v1/me* {
		reverse_proxy 127.0.0.1:8090 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}

	# ---- PHASE-9 Bucket 3 — admin via dispatcher ---- #
	# /v1/admin/* (52+ rotas com RBAC permissions) → dispatcher → core.
	# Core é fork 1:1 do legacy, mesma RBAC, mesma adminAuth middleware,
	# mesmo DB. Tokens admin são dual-signed (RS256+HS256) → interchangeable.
	# Parity pré-swap: 12 rotas testadas, 401 sem Bearer em ambos paths,
	# bodies idênticos exceto trace_id. Risco baixo (mesma surface, mesmo DB).
	handle /v1/admin* {
		reverse_proxy 127.0.0.1:8090 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}

	# Default — tudo que não bateu nos handle_path acima vai pro monolito.
	reverse_proxy 127.0.0.1:8080 {
		header_up X-Real-IP {http.request.remote.host}
	}

	log {
		output stderr
		format json
	}
}
