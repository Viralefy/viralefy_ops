# Viralefy — Caddy reverse proxy + TLS automático.
# Variáveis vêm de /etc/caddy/viralefy.env (DOMAIN_*, CADDY_EMAIL).
# Apps escutam só em 127.0.0.1; Caddy é a única superfície pública.

{
	email {$CADDY_EMAIL}
	servers {
		trusted_proxies static private_ranges
	}
	# Ordem de directives — coraza_waf precisa rodar ANTES do reverse_proxy.
	# Sem isso, requests passam pro upstream antes do WAF inspecionar.
	order coraza_waf first
}

# ---------------- Catch-all pra Host headers desconhecidos (pentest #4) ---------------- #
# Pentest 2026-06-10 finding #4: `curl -H "Host: evil.example.com"` em /healthz
# devolvia 200. Caddy roteia por Host; quando HTTP/2 reusa conexão TLS de um
# domínio válido, Caddy v2 pode dispatch ao primeiro site block. Defesa:
# bloco wildcard explícito que responde 421 Misdirected Request pra qualquer
# Host que não bata em um dos vhosts explícitos abaixo. RFC 7540 §9.1.2 é o
# status correto. O TLS handshake usa cert interno (Caddy internal) pra Host
# desconhecido — atacante vê cert mismatch antes do request.
:443 {
	tls internal
	respond "Misdirected Request" 421 {
		close
	}
}
:80 {
	respond "Misdirected Request" 421 {
		close
	}
}

# ---------------- apex → www (canônico flipped) ---------------- #
# A loja é canônica em www.viralefy.com. Apex viralefy.com redireciona 301
# preservando path/query — bookmarks e backlinks históricos continuam vivos.
#
# IMPORTANTE: capturamos http:// e https:// explicitamente pra evitar a hop
# intermediária do Caddy global handler (que faria http://apex → https://apex
# antes do redir). Cadeia HTTP→HTTPS→www = 2 hops e Ahrefs flagga como
# "redirect chain". Com os 2 blocos abaixo, http://apex → https://www em UM
# único 301, e https://apex → https://www em UM único 301.
http://{$DOMAIN_FRONT} {
	redir https://www.{$DOMAIN_FRONT}{uri} 301
}
{$DOMAIN_FRONT} {
	redir https://www.{$DOMAIN_FRONT}{uri} 301
}

# ---------------- Loja (canônica em www) ---------------- #
www.{$DOMAIN_FRONT} {
	encode zstd gzip

	header {
		# HSTS (1 ano, subdomínios, preload).
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "interest-cohort=(), browsing-topics=()"
		Cross-Origin-Opener-Policy "same-origin"
		# X-Robots-Tag explícito (default seria indexar tudo, mas Ahrefs flagga
		# como "Ausente" quando não tem header). /account /tickets /login etc.
		# já bloqueados por robots.txt + meta robots noindex no Next.js, então
		# não duplicamos via X-Robots-Tag aqui (override no Caddy não tava
		# pegando consistentemente).
		X-Robots-Tag "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
		# Pentest #7: Cross-Origin-Resource-Policy isola este recurso de leitura
		# cross-origin opaca (Spectre-class). same-site permite cdn.viralefy.com
		# e api.viralefy.com, bloqueia eTLD+1 estrangeiro.
		# COEP `require-corp` ficou DEFERIDO — quebraria GTM/Turnstile/Twemoji
		# CDNs que não enviam CORP nas suas respostas. Reativar quando
		# migrarmos GTM pra self-hosted e Turnstile já tiver suporte CORP.
		Cross-Origin-Resource-Policy "same-site"
		-Server
		-X-Powered-By
	}

	reverse_proxy 127.0.0.1:3000 {
		header_up X-Real-IP {http.request.remote.host}
	}

	log {
		output stderr
		format json
	}
}

# ---------------- Backoffice ---------------- #
{$DOMAIN_BACKOFFICE} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Content-Security-Policy "frame-ancestors 'none'"
		Permissions-Policy "interest-cohort=(), browsing-topics=()"
		Cross-Origin-Opener-Policy "same-origin"
		# COEP require-corp DESLIGADO (2026-06-11): bloqueava o loader do
		# Cloudflare Turnstile (challenges.cloudflare.com/turnstile/v0/api.js)
		# usado no /login admin — Turnstile não envia Cross-Origin-Resource-
		# Policy header, então com require-corp o browser refusa o script e o
		# captcha nunca aparece (UX: "can't login" + CORS error no console).
		# Reativar quando Turnstile passar a enviar CORP (issue Cloudflare aberto)
		# ou quando o admin migrar pra solução self-hosted de captcha.
		#
		# COOP same-origin continua = ainda isola o contexto contra leitura
		# cross-origin. CORP same-origin permanece restritivo no nosso lado.
		Cross-Origin-Resource-Policy "same-origin"
		-Server
		-X-Powered-By
	}

	# /api/metrics é o endpoint Prometheus do backoffice (raspado em loopback
	# por prometheus em 127.0.0.1:9090, vide viralefy_ops/config/prometheus.yml).
	# Externamente NUNCA pode vazar — métricas de processo dão fingerprinting
	# (uptime, RSS, GC patterns) e a cardinalidade de http_requests_total
	# expõe rotas internas. Retornamos 404 (não 403) pra não revelar a rota.
	@backoffice_metrics path /api/metrics
	handle @backoffice_metrics {
		respond "Not Found" 404 {
			close
		}
	}

	reverse_proxy 127.0.0.1:3001 {
		header_up X-Real-IP {http.request.remote.host}
	}

	log {
		output stderr
		format json
	}
}

# ---------------- Observability (Grafana) ---------------- #
{$DOMAIN_OBS} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Cross-Origin-Opener-Policy "same-origin"
		# Pentest #7: Grafana é sistema fechado interno.
		Cross-Origin-Resource-Policy "same-origin"
		-Server
		-X-Powered-By
	}

	# Grafana escuta em 127.0.0.1:3030 (3000 já é do viralefy-front).
	reverse_proxy 127.0.0.1:3030 {
		header_up X-Real-IP {http.request.remote.host}
	}

	log {
		output stderr
		format json
	}
}

# ---------------- Auth (identidade unificada) ---------------- #
# 2026-06-11 — `auth.viralefy.com` é o host dedicado para identidade.
# Serve apenas `/v1/auth/*` + `/.well-known/jwks.json` proxy-passando pro
# dispatcher (que delega ao viralefy_auth :8083). Resto retorna 404.
#
# Por que separar de api.viralefy.com:
#   - Identidade tem CORS/CSP/COOP separados (auth flow vai precisar
#     POST-redirect-GET pra SSO futuro, cookies httponly etc.).
#   - Token de admin e user são MINTED aqui; isolar a superfície de ataque
#     do resto da API (que serve marketplace, pagamentos etc.).
#   - Permite mover front + backoffice para `NEXT_PUBLIC_AUTH_URL` sem
#     mexer no `NEXT_PUBLIC_API_URL` (graceful rollout, env por env).
#
# DNS: até existir um A/AAAA pra auth.viralefy.com, Caddy serve TLS via
# Let's Encrypt assim que o registro for criado. Front/backoffice já
# conseguem apontar pra esse host sem aguardar — `NEXT_PUBLIC_AUTH_URL`
# default cai pra api.viralefy.com como fallback (vide front/backoffice
# lib/api.ts).
{$DOMAIN_AUTH:auth.viralefy.com} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin"
		Cross-Origin-Opener-Policy "same-origin"
		# Auth serve só JSON. Mesma postura do API host.
		Cross-Origin-Resource-Policy "same-site"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=(), browsing-topics=(), payment=(), usb=()"
		-Server
		-X-Powered-By
	}

	# WAF — mesmas exclusions do api host (login + register são FP-heavy
	# por causa de tokens Turnstile / cookies GA).
	coraza_waf {
		directives `
			Include /etc/caddy/coraza/coraza.conf
			Include /etc/caddy/coraza/crs/crs-setup.conf
			Include /etc/caddy/coraza/coraza-crs-exclusions.conf
			Include /etc/caddy/coraza/crs/rules/*.conf
		`
	}

	# CORS — replica o do api host. Origin reflectido se presente.
	@cors_preflight_auth {
		method OPTIONS
		header Origin *
	}
	handle @cors_preflight_auth {
		header {
			Access-Control-Allow-Origin "{header.Origin}"
			Access-Control-Allow-Credentials "true"
			Access-Control-Allow-Methods "GET, POST, PUT, DELETE, PATCH, OPTIONS"
			Access-Control-Allow-Headers "Content-Type, Authorization, X-Request-Id, Idempotency-Key, Accept, Accept-Language, User-Agent"
			Access-Control-Max-Age "600"
			Vary "Origin"
		}
		respond "" 204 {
			close
		}
	}
	@has_origin_auth header Origin *
	header @has_origin_auth {
		Access-Control-Allow-Origin "{header.Origin}"
		Access-Control-Allow-Credentials "true"
		Vary "Origin"
	}

	# Defesa em profundidade: /internal/* nunca vaza.
	@internal_auth path /internal/*
	handle @internal_auth {
		respond "Not Found" 404 {
			close
		}
	}

	# JWKS — direto pro auth, com cache 60s no edge.
	handle /.well-known/jwks.json {
		header Cache-Control "public, max-age=60, stale-while-revalidate=300"
		reverse_proxy 127.0.0.1:8083 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}

	# Health pra balanceadores externos. Não exige WAF.
	handle /health {
		reverse_proxy 127.0.0.1:8083 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}

	# Rotas de auth — via dispatcher (mantém JWT issuance dual-sign,
	# rate limit, observability). Default 404 pra qualquer outro path.
	handle /v1/auth* {
		reverse_proxy 127.0.0.1:8090 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}

	# Default — 404 explícito (auth host só responde auth).
	respond "Not Found" 404 {
		close
	}

	log {
		output stderr
		format json
	}
}

# ---------------- API ---------------- #
{$DOMAIN_API} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin"
		Cross-Origin-Opener-Policy "same-origin"
		# Pentest #7: API serve só JSON. same-site permite www.viralefy.com
		# (mesmo eTLD+1) acessar via fetch com CORS; bloqueia cross-origin
		# leakage de respostas pra contextos hostis.
		Cross-Origin-Resource-Policy "same-site"
		# Hardening test 2026-06-11: API só serve JSON. Bloqueia features
		# do browser que API nunca deveria pedir — defense em profundidade.
		Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=(), browsing-topics=(), payment=(), usb=()"
		-Server
		-X-Powered-By
	}

	# ---- Coraza WAF — OWASP CRS 4.x ---- #
	# PHASE-9 §3.1. Defesa em profundidade contra XSS, SQLi, path traversal,
	# command injection antes de qualquer roteamento pros services Go.
	#
	# Modo inicial: DetectionOnly (audit em /var/log/caddy-waf/audit.log,
	# não bloqueia ainda). Janela mínima de 14 dias coletando false positives
	# antes de mudar pra Block. Tuning de exceções fica em CRS_EXCLUSION_*
	# config no crs-setup.conf.
	#
	# Limites cobertos pelo CRS (NÃO substitui validação de domínio):
	#   - SQLi (rules 942xxx)
	#   - XSS (rules 941xxx)
	#   - LFI/path traversal (rules 930xxx, 932xxx)
	#   - RCE (rules 932xxx)
	#   - HTTP protocol violations (920xxx)
	# NÃO cobre IDOR/BOLA, mass-assignment, business logic — esses ficam
	# em viralefy_core/middlewares (vide PHASE-9-ARCHITECTURE §3.2).
	coraza_waf {
		directives `
			Include /etc/caddy/coraza/coraza.conf
			Include /etc/caddy/coraza/crs/crs-setup.conf
			Include /etc/caddy/coraza/coraza-crs-exclusions.conf
			Include /etc/caddy/coraza/crs/rules/*.conf
		`
	}

	# /health e /ready continuam públicos (necessários p/ load balancers).

	# ---- CORS — PHASE-9 ---- #
	# Legacy api tinha go-chi/cors middleware. Após cutover, core mantém
	# o middleware mas auth/dispatcher NÃO têm. Browser de www.viralefy.com
	# faz preflight OPTIONS pra api.viralefy.com — sem resposta válida,
	# fetch falha com "TypeError: Failed to fetch" / network error.
	# Fix: Caddy responde CORS na borda pra TODAS rotas /v1/*.
	@cors_preflight {
		method OPTIONS
		header Origin *
	}
	handle @cors_preflight {
		header {
			Access-Control-Allow-Origin "{header.Origin}"
			Access-Control-Allow-Credentials "true"
			Access-Control-Allow-Methods "GET, POST, PUT, DELETE, PATCH, OPTIONS"
			Access-Control-Allow-Headers "Content-Type, Authorization, X-Request-Id, Idempotency-Key, Accept, Accept-Language, User-Agent"
			Access-Control-Max-Age "600"
			Vary "Origin"
		}
		respond "" 204 {
			close
		}
	}
	# Em responses normais (não-OPTIONS), adicionar CORS headers se Origin presente.
	# Caddy aplica esses headers em TODAS responses do bloco.
	@has_origin header Origin *
	header @has_origin {
		Access-Control-Allow-Origin "{header.Origin}"
		Access-Control-Allow-Credentials "true"
		Vary "Origin"
	}

	# ---- Defesa em profundidade: /internal/* nunca pode vazar pra fora ---- #
	# Os endpoints /internal/v1/* são callbacks loopback entre microservices
	# (PHASE-8). Já são gateados por X-Internal-Token, mas: 1) o token vaza se
	# logamos request body em erro, 2) qualquer probe externo conseguia ver
	# 401 + trace_id (info disclosure), 3) bruteforce era teoricamente possível.
	# Bloqueio na borda fecha as 3 brechas. Retornamos 404 (não 403) pra não
	# revelar que a rota existe.
	@internal path /internal/*
	handle @internal {
		respond "Not Found" 404 {
			close
		}
	}

	# ---- Webhooks de pagamento → viralefy_payments (127.0.0.1:8081) ---- #
	# Stripe/Heleket/Woovi/AbacatePay entregam em api.viralefy.com/v1/webhooks/
	# <provider>; o microservice valida assinatura + idempotência e chama o
	# callback interno na API monolítica.
	#
	# IMPORTANTE: usamos `handle` (não `handle_path`) + rewrite pra preservar
	# o path e PREPENDER `/internal`. Assim a rota no payments é
	# `POST /internal/v1/webhooks/<provider>` — case com o router de lá.
	handle /v1/webhooks/stripe* {
		rewrite * /internal{path}
		reverse_proxy 127.0.0.1:8081 {
			header_up X-Real-IP {http.request.remote.host}
			header_up X-Forwarded-Webhook "stripe"
		}
	}
	handle /v1/webhooks/heleket* {
		rewrite * /internal{path}
		reverse_proxy 127.0.0.1:8081 {
			header_up X-Real-IP {http.request.remote.host}
			header_up X-Forwarded-Webhook "heleket"
		}
	}
	handle /v1/webhooks/woovi* {
		rewrite * /internal{path}
		reverse_proxy 127.0.0.1:8081 {
			header_up X-Real-IP {http.request.remote.host}
			header_up X-Forwarded-Webhook "woovi"
		}
	}
	handle /v1/webhooks/abacatepay* {
		rewrite * /internal{path}
		reverse_proxy 127.0.0.1:8081 {
			header_up X-Real-IP {http.request.remote.host}
			header_up X-Forwarded-Webhook "abacatepay"
		}
	}

	# ---- PHASE-9 Bucket 1 — public read-only via dispatcher (:8090) ---- #
	# Strangler cutover por bucket: rotas idempotentes e públicas (sem auth)
	# vão pra Rust dispatcher → routes pra viralefy_core (:8084) ou viralefy_auth
	# (:8083, no caso de JWKS). Parity 100% validada antes do swap (status+body
	# identical legacy vs dispatcher pra todos os paths abaixo).
	#
	# Rollback: comentar este bloco e reload Caddy — volta pro :8080 monolito.
	# Bucket 2 (auth user), 3 (admin), 4 (checkout) seguem em sessões futuras.
	handle /v1/plans* {
		reverse_proxy 127.0.0.1:8090 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}
	handle /v1/categories* {
		reverse_proxy 127.0.0.1:8090 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}
	handle /v1/currencies* {
		reverse_proxy 127.0.0.1:8090 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}
	handle /v1/status* {
		reverse_proxy 127.0.0.1:8090 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}
	handle /v1/country-ppp* {
		reverse_proxy 127.0.0.1:8090 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}
	handle /v1/tax-rates* {
		reverse_proxy 127.0.0.1:8090 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}
	# JWKS — bypass dispatcher rate limit (SEV-2 fix 2026-06-11)
	# Verifiers externos (SDK clients, payment webhooks, sender) precisam
	# JWKS sempre acessível. Dispatcher tem tower_governor 30 burst + 1/s
	# per-IP, que bloqueava JWKS após poucos hits. Caddy direto pra auth
	# bypassa o limite + adiciona Cache-Control 60s pra browser/CDN cache.
	handle /.well-known/jwks.json {
		header Cache-Control "public, max-age=60, stale-while-revalidate=300"
		reverse_proxy 127.0.0.1:8083 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}

	# ---- PHASE-9 Bucket 2 (a+b) — área logada do usuário via dispatcher ---- #
	# /v1/me/* (GET + POST + PUT + DELETE) — 38 rotas. Parity pré-swap: 401
	# sem Bearer em ambos legacy e dispatcher, body shape idêntico (só
	# trace_id varia). Dual-sign já existe em legacy → tokens RS256 emitidos
	# por auth/core/legacy são interchangeable, sem auth chain break.
	# DB compartilhado → mutações idempotentes mesmo se path alternar.
	handle /v1/me* {
		reverse_proxy 127.0.0.1:8090 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}

	# ---- PHASE-9 Bucket 3 — admin via dispatcher ---- #
	# /v1/admin/* (52+ rotas com RBAC permissions) → dispatcher → core.
	# Core é fork 1:1 do legacy, mesma RBAC, mesma adminAuth middleware,
	# mesmo DB. Tokens admin são dual-signed (RS256+HS256) → interchangeable.
	# Parity pré-swap: 12 rotas testadas, 401 sem Bearer em ambos paths,
	# bodies idênticos exceto trace_id. Risco baixo (mesma surface, mesmo DB).
	handle /v1/admin* {
		reverse_proxy 127.0.0.1:8090 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}

	# ---- PHASE-9 Bucket 2c — auth flows via viralefy_auth ---- #
	# /v1/auth/{user/register,user/login,user/login/2fa,login,login/2fa,login/2fa/enroll}
	# → dispatcher → viralefy_auth (:8083). Public routes adicionadas em
	# auth (commit ed5ead4) que delegam aos handlers internos derivando
	# kind:user|admin do path. Rate limit in-memory 10/15min per-IP via
	# X-Real-IP propagado pelo Caddy → dispatcher → auth. RS256 mint usa
	# mesma RSA key compartilhada → tokens interchangeable com legacy/core.
	handle /v1/auth* {
		reverse_proxy 127.0.0.1:8090 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}

	# ---- PHASE-9 Bucket 4 — checkout via dispatcher → core ---- #
	# POST /v1/checkout (anonymous checkout possível via optionalUserAuth).
	# Mesma codepath em legacy e core (fork 1:1), mesma DB, mesmas chaves
	# Stripe/Heleket/Woovi/Abacate em /etc/viralefy/.env. Parity pré-swap:
	# 422 INVALID_INPUT em ambos paths com body vazio, idem com Idempotency-Key.
	# Nota: StripeReconcileCron roda em BOTH legacy e core (background poll
	# de Stripe Sessions API). Idempotente (UPDATE...WHERE confirmed_at IS NULL),
	# mas duplica API calls. TODO: desabilitar cron no legacy quando legacy
	# for parado de vez (post-soak 14d). Webhooks `/v1/webhooks/*` continuam
	# direto pra viralefy_payments (handle blocks acima), inalterados.
	handle /v1/checkout* {
		reverse_proxy 127.0.0.1:8090 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}

	# Default — fallback pro dispatcher (PHASE-9 finalizado). Dispatcher
	# tem resolve_upstream que roteia path-by-path pra core/auth/payments.
	# Paths desconhecidos vão pra core (default no dispatcher), que retorna
	# 404 — mesmo comportamento do legacy. Stack legacy api (:8080) está
	# parada em soak (vide .legacy-deprecated em prod).
	reverse_proxy 127.0.0.1:8090 {
		header_up X-Real-IP {http.request.remote.host}
	}

	log {
		output stderr
		format json
	}
}
