[Unit]
Description=Viralefy — disparador diário do verify de backups
Documentation=https://github.com/Viralefy/viralefy_ops

[Timer]
# 04:00 UTC — ~1h após o backup (03:00 + até 30min jitter). Persistente
# pra recuperar runs perdidos quando a VPS estava off.
OnCalendar=*-*-* 04:00:00 UTC
RandomizedDelaySec=15min
Persistent=true
Unit=viralefy-backup-verify.service

[Install]
WantedBy=timers.target
