[Unit]
Description=Viralefy — cleanup hourly de fixtures @viralefy.test deixadas pelo viralefy-smoke
Documentation=https://github.com/Viralefy/viralefy_ops
Wants=network-online.target postgresql.service
After=network-online.target postgresql.service

[Service]
Type=oneshot
# DATABASE_URL vem do .env compartilhado da app.
EnvironmentFile=/etc/viralefy/.env
Environment=TEXTFILE_PATH=/var/lib/node_exporter/textfile_collector/viralefy_test_cleanup.prom
ExecStart=/usr/local/sbin/viralefy-test-cleanup
User=viralefy-core
Group=viralefy

# Falha sai com 1 (erro DB ou tx) ou 2 (erro infra). Em ambos, journal
# captura stderr + stdout e systemd marca o unit como failed pro alert ops.
# exit 0 = limpeza OK (mesmo 0 rows removidas é sucesso — idempotência).
StandardOutput=journal
StandardError=journal
TimeoutStartSec=5min

# Hardening — escreve em DB + 1 arquivo .prom; sem mais nada.
NoNewPrivileges=true
ProtectSystem=strict
# textfile collector path precisa ser gravável; expomos só esse dir.
ReadWritePaths=/var/lib/node_exporter/textfile_collector
ProtectHome=true
PrivateTmp=true
PrivateDevices=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectKernelLogs=true
ProtectControlGroups=true
ProtectClock=true
ProtectHostname=true
ProtectProc=invisible
ProcSubset=pid
RestrictSUIDSGID=true
RestrictRealtime=true
RestrictNamespaces=true
LockPersonality=true
MemoryDenyWriteExecute=true
SystemCallArchitectures=native
SystemCallFilter=@system-service
SystemCallFilter=~@privileged @resources @debug @mount @cpu-emulation @obsolete
CapabilityBoundingSet=
AmbientCapabilities=
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX

[Install]
WantedBy=multi-user.target
