{
  "_comment": "Viralefy — Reliability/SRE dashboard. Real metrics: http_requests_total, http_request_duration_seconds_bucket, db_query_duration_seconds_*, plus node_exporter (CPU/mem per systemd unit via node_systemd_unit_*), plus process_resident_memory_bytes / go_* from each service. The 'job' label is set in prometheus.yml (currently only 'viralefy-api'); when viralefy-core/payments/sender/dispatcher are added to scrape config, this dashboard auto-detects them via the $service variable.",
  "_todo_metrics": [
    "viralefy_db_pool_open_connections / viralefy_db_pool_max_connections (gauge) — wrap *sql.DB.Stats() periodically. Required for DB pool saturation panel.",
    "viralefy_dispatcher_rate_limit_429_total{route} — counter in Rust dispatcher rate-limit layer.",
    "viralefy_smoke_test_failures_total{suite} (or last_success_timestamp_seconds gauge) — from CI/cron smoke runner.",
    "Postgres exporter (postgres_exporter on :9187) not yet in prometheus.yml — DB system metrics fall back to pg_stat_* once added."
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Saúde do stack: 5xx por serviço, latência p50/p95/p99, mem/CPU por unit systemd, saturação do pool de DB, 429 do dispatcher, falhas de smoke test.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "PHASE-9 services detail",
      "tooltip": "Dashboard com paineis por microservice (core/auth/dispatcher/payments/sender/backoffice/front)",
      "type": "link",
      "url": "/d/viralefy-phase9"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Status up/down dos jobs scraped. Métrica padrão Prometheus 'up'.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" } }, "type": "value" },
            { "options": { "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "up{job=~\"viralefy-.*|node|caddy|postgres-exporter\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Service up/down",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Error budget burn — 5xx ratio global (5m). Limite SLO sugerido: 0.1%.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.001 },
              { "color": "red", "value": 0.01 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 0.1,
          "decimals": 4
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1)",
          "legendFormat": "5xx ratio",
          "refId": "A"
        }
      ],
      "title": "Global 5xx ratio (5m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Falhas de smoke test na última 1h. TODO: requer viralefy_smoke_test_failures_total.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(viralefy_smoke_test_failures_total[1h]))",
          "legendFormat": "failures",
          "refId": "A"
        }
      ],
      "title": "Smoke test failures (1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "5xx rate por serviço. Quando viralefy-core/payments/sender forem adicionados ao prometheus.yml com label service=, aparecem aqui automaticamente.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "percentunit",
          "min": 0,
          "decimals": 4
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "id": 4,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (service) (rate(http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum by (service) (rate(http_requests_total[5m])), 1)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "5xx ratio per service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Latência p50/p95/p99 por serviço. Métrica real http_request_duration_seconds_bucket.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by (le, service) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{service}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le, service) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{service}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by (le, service) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{service}}",
          "refId": "C"
        }
      ],
      "title": "Request latency p50/p95/p99 per service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "RSS do processo por serviço. Métrica real process_resident_memory_bytes (do client_golang).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 6,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "process_resident_memory_bytes{job=~\"viralefy-.*\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Memory RSS per service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "CPU rate por serviço (segundos de CPU / segundo). Métrica real process_cpu_seconds_total.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 7,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(process_cpu_seconds_total{job=~\"viralefy-.*\"}[5m])",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "CPU usage per service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Memória por unit systemd via node_exporter (--collector.systemd). Necessita --collector.systemd habilitado no node_exporter.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "id": 8,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "node_systemd_unit_memory_current_bytes{name=~\"viralefy-.*\\\\.service\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "Memory per systemd unit (node_exporter)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Saturação do pool de conexões DB — open / max. TODO: requer viralefy_db_pool_open_connections + viralefy_db_pool_max_connections (wrap sql.DB.Stats()).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "id": 9,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "viralefy_db_pool_open_connections / clamp_min(viralefy_db_pool_max_connections, 1)",
          "legendFormat": "{{service}} pool saturation",
          "refId": "A"
        }
      ],
      "title": "DB pool saturation (open/max)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Latência de queries DB por tipo lógico (p95). Métrica real db_query_duration_seconds_bucket.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "id": 10,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le, query_type) (rate(db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{query_type}}",
          "refId": "A"
        }
      ],
      "title": "DB query p95 by query_type",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Contagem de 429 do dispatcher (rate-limit). TODO: requer viralefy_dispatcher_rate_limit_429_total{route} — dispatcher hoje só expõe tracing JSON.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 38 },
      "id": 11,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (route) (increase(viralefy_dispatcher_rate_limit_429_total[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "Dispatcher 429 rate-limit hits (5m buckets)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Overhead introduzido pelo dispatcher (excluindo tempo upstream) — p95 por upstream. Métrica real dispatcher_overhead_seconds_bucket{upstream}. Target SLO: p95 <50ms.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 45 },
      "id": 12,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le, upstream) (rate(dispatcher_overhead_seconds_bucket[5m])))",
          "legendFormat": "p95 {{upstream}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by (le, upstream) (rate(dispatcher_overhead_seconds_bucket[5m])))",
          "legendFormat": "p99 {{upstream}}",
          "refId": "B"
        }
      ],
      "title": "Dispatcher overhead p95/p99 by upstream (target <50ms)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Latência upstream (core/auth/payments) p95 vista pelo dispatcher. Métrica real dispatcher_upstream_seconds_bucket{upstream}. Útil pra distinguir latência de rede+app vs overhead próprio do dispatcher.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 45 },
      "id": 13,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le, upstream) (rate(dispatcher_upstream_seconds_bucket[5m])))",
          "legendFormat": "p95 {{upstream}}",
          "refId": "A"
        }
      ],
      "title": "Dispatcher upstream latency p95 by target",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Idade do último tick do cron Stripe reconcile do core. Verde <5min, amarelo 5-10min, vermelho >10min. Gauge real viralefy_stripe_reconcile_last_run_timestamp.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 300 },
              { "color": "red", "value": 600 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 52 },
      "id": 14,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "time() - viralefy_stripe_reconcile_last_run_timestamp",
          "legendFormat": "Stripe reconcile age",
          "refId": "A"
        }
      ],
      "title": "Stripe reconcile last-run age (core cron)",
      "type": "stat"
    }
