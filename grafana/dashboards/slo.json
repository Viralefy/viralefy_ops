    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "api.viralefy.com availability (30d). Target 99.5%. Verde > target, amarelo target±0.3%, vermelho < target.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 99.2 },
              { "color": "green", "value": 99.5 }
            ]
          },
          "unit": "percent",
          "decimals": 3,
          "min": 95,
          "max": 100
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "100 * (1 - (sum(rate(http_requests_total{service=\"viralefy-api\",status=~\"5..\"}[30d])) / clamp_min(sum(rate(http_requests_total{service=\"viralefy-api\"}[30d])), 1)))",
          "legendFormat": "api availability 30d",
          "refId": "A"
