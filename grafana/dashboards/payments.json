{
  "_comment": "Viralefy — Payments dashboard. The only real payment-related metric currently exposed is gateway_callbacks_total{provider,status} (see viralefy_api/internal/infrastructure/observability/metrics.go). Other panels (pending->confirmed latency, idempotency hits, reconcile cron status, volume in fiat) require new collectors in viralefy-payments service. TODOs documented below.",
  "_todo_metrics": [
    "viralefy_payment_pending_to_confirmed_seconds (histogram) — observe time between order.created and order.paid per provider.",
    "viralefy_idempotency_hits_total{provider,result=hit|miss} — counter from payments idempotency-key cache.",
    "viralefy_stripe_reconcile_last_success_timestamp_seconds (gauge) — set by cron job on success.",
    "viralefy_stripe_reconcile_runs_total{result=ok|error} — counter from cron.",
    "viralefy_payment_volume_total{provider,currency} — sum of paid order amounts per provider."
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Webhook success/failure por provider (Stripe/Heleket/Woovi/AbacatePay), latência pending->confirmed, idempotency hits, status do reconcile cron, volume por provider.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Webhook success ratio nas últimas 5min — (não-erros) / total. Métrica real gateway_callbacks_total.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 4
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(gateway_callbacks_total{status!~\"error|invalid|rejected|failed|signature_invalid\"}[5m])) / clamp_min(sum(rate(gateway_callbacks_total[5m])), 1)",
          "legendFormat": "success",
          "refId": "A"
        }
      ],
      "title": "Overall webhook success ratio (5m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "p95 do tempo entre pending e confirmed por provider. TODO: requer histogram viralefy_payment_pending_to_confirmed_seconds.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 60 },
              { "color": "red", "value": 300 }
            ]
          },
          "unit": "s",
          "decimals": 1
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(viralefy_payment_pending_to_confirmed_seconds_bucket[15m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "title": "Pending → confirmed p95 (15m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Idade do último reconcile bem-sucedido. TODO: requer gauge viralefy_stripe_reconcile_last_success_timestamp_seconds.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3600 },
              { "color": "red", "value": 21600 }
            ]
          },
          "unit": "s",
          "decimals": 0
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "time() - viralefy_stripe_reconcile_last_success_timestamp_seconds",
          "legendFormat": "age",
          "refId": "A"
        }
      ],
      "title": "Stripe reconcile cron — age of last success",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Hit ratio do cache de idempotency keys (proteção contra retry de webhooks). TODO: requer viralefy_idempotency_hits_total{result}.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 3
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(viralefy_idempotency_hits_total{result=\"hit\"}[5m])) / clamp_min(sum(rate(viralefy_idempotency_hits_total[5m])), 1)",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ],
      "title": "Idempotency cache hit ratio",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Webhooks recebidos por provider e status (métrica real gateway_callbacks_total).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "callbacks/s",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (provider, status) (rate(gateway_callbacks_total[5m]))",
          "legendFormat": "{{provider}} / {{status}}",
          "refId": "A"
        }
      ],
      "title": "Webhook rate by provider/status",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Webhook success ratio por provider — quem está falhando mais?",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 4
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "id": 6,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "min"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (provider) (rate(gateway_callbacks_total{status!~\"error|invalid|rejected|failed|signature_invalid\"}[5m])) / clamp_min(sum by (provider) (rate(gateway_callbacks_total[5m])), 1)",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "title": "Webhook success ratio per provider (5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Distribuição p50/p95/p99 do tempo pending → confirmed. TODO: requer viralefy_payment_pending_to_confirmed_seconds.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 7,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by (le, provider) (rate(viralefy_payment_pending_to_confirmed_seconds_bucket[15m])))",
          "legendFormat": "p50 {{provider}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(viralefy_payment_pending_to_confirmed_seconds_bucket[15m])))",
          "legendFormat": "p95 {{provider}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by (le, provider) (rate(viralefy_payment_pending_to_confirmed_seconds_bucket[15m])))",
          "legendFormat": "p99 {{provider}}",
          "refId": "C"
        }
      ],
      "title": "Pending → confirmed latency p50/p95/p99 per provider",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Volume pago por provider (em USD). TODO: requer viralefy_payment_volume_total{provider,currency}.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 8,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (provider) (increase(viralefy_payment_volume_total{currency=\"USD\"}[1h]))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "title": "Payment volume USD per provider (1h buckets)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Runs do cron de reconciliação Stripe — ok vs erro. TODO: requer viralefy_stripe_reconcile_runs_total{result}.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 22 },
      "id": 9,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (result) (increase(viralefy_stripe_reconcile_runs_total[1h]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "title": "Stripe reconcile cron runs (1h buckets)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["viralefy", "production", "payments"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
