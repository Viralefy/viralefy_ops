{
  "_comment": "Viralefy — User behavior dashboard. Real metrics used: http_requests_total{method,path,status}, http_request_duration_seconds_bucket{method,path}. The path label uses chi route patterns so /v1/me/* aggregates work via regex. Auth/2FA/Coraza/dispatcher routing panels require new collectors documented as TODOs.",
  "_todo_metrics": [
    "viralefy_auth_attempts_total{result=success|invalid_password|invalid_2fa|locked} — counter in auth handler.",
    "viralefy_2fa_users_total / viralefy_users_total — gauges (or use postgres-exporter) for enrollment %.",
    "viralefy_dispatcher_routes_total{upstream} — counter in Rust dispatcher (axum) per upstream forwarded.",
    "viralefy_coraza_rule_matches_total{rule_id,severity,action} — counter from Coraza WAF middleware."
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Comportamento de usuários: login attempts vs success, 2FA enrollment, /v1/me/* p95, top endpoints por RPS, routing do dispatcher, detecções Coraza WAF.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Taxa de login bem-sucedido nas últimas 15min. TODO: requer viralefy_auth_attempts_total{result}.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.6 },
              { "color": "green", "value": 0.85 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 3
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(viralefy_auth_attempts_total{result=\"success\"}[15m])) / clamp_min(sum(rate(viralefy_auth_attempts_total[15m])), 1)",
          "legendFormat": "success ratio",
          "refId": "A"
        }
      ],
      "title": "Login success ratio (15m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "% de usuários com 2FA habilitado. TODO: requer gauges viralefy_2fa_users_total e viralefy_users_total.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.2 },
              { "color": "green", "value": 0.5 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 3
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "viralefy_2fa_users_total / clamp_min(viralefy_users_total, 1)",
          "legendFormat": "2FA %",
          "refId": "A"
        }
      ],
      "title": "2FA enrollment %",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "p95 das rotas /v1/me/* (área autenticada do usuário). Métrica real http_request_duration_seconds_bucket.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.3 },
              { "color": "red", "value": 1.0 }
            ]
          },
          "unit": "s",
          "decimals": 3
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{path=~\"/v1/me/.*\"}[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "title": "/v1/me/* p95 (5m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Total de logins falhos por motivo nas últimas 15min. TODO: requer viralefy_auth_attempts_total{result}.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(viralefy_auth_attempts_total{result!=\"success\"}[15m]))",
          "legendFormat": "failed",
          "refId": "A"
        }
      ],
      "title": "Failed logins (15m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Tentativas de login por resultado (success vs invalid_password vs invalid_2fa vs locked). Útil pra detectar brute-force. TODO: requer viralefy_auth_attempts_total.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (result) (rate(viralefy_auth_attempts_total[1m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "title": "Login attempts by result",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Top 10 endpoints por RPS (métrica real http_requests_total{path}, agregada por route pattern do chi).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "id": 6,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "topk(10, sum by (path) (rate(http_requests_total[5m])))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "title": "Top 10 endpoints by RPS",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Latência das rotas /v1/me/* — p50/p95/p99 quebrada por path. Métrica real http_request_duration_seconds_bucket.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 7,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le, path) (rate(http_request_duration_seconds_bucket{path=~\"/v1/me/.*\"}[5m])))",
          "legendFormat": "p95 {{path}}",
          "refId": "A"
        }
      ],
      "title": "/v1/me/* p95 by route",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "% do tráfego roteado pelo dispatcher (Rust axum) por upstream. TODO: requer viralefy_dispatcher_routes_total{upstream} — o dispatcher hoje só tem tracing JSON, sem Prometheus.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "percent" }
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 8,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (upstream) (rate(viralefy_dispatcher_routes_total[5m])) / ignoring(upstream) group_left sum(rate(viralefy_dispatcher_routes_total[5m]))",
          "legendFormat": "{{upstream}}",
          "refId": "A"
        }
      ],
      "title": "Dispatcher routing breakdown (% per upstream)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Detecções do Coraza WAF agrupadas por rule_id e severity. TODO: requer viralefy_coraza_rule_matches_total.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 70,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 22 },
      "id": 9,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "topk(15, sum by (rule_id, severity) (increase(viralefy_coraza_rule_matches_total[1h])))",
          "legendFormat": "{{rule_id}} ({{severity}})",
          "refId": "A"
        }
      ],
      "title": "Coraza WAF detections by rule (1h)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["viralefy", "production", "behavior"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Viralefy — Behavior",
  "uid": "viralefy-behavior",
  "version": 1,
  "weekStart": ""
}
