        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(http_requests_total{service=\"viralefy-core\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{service=\"viralefy-core\"}[5m])), 1)",
