{
  "_comment": "Viralefy — PHASE-9 services dashboard. Métricas REAIS expostas pelos microservices (verificadas via curl /metrics e /internal/metrics em prod). Filtra por label service= (injetada pelo Prometheus via static_configs em prometheus.yml). Métricas inexistentes (gateway_callbacks_total, sender_outbox_dispatch_total, dispatcher_rate_limit_429_total, JWT verify failures, JWKS cache, 2FA enroll, webhook signature) NÃO foram inventadas — ver _todo_metrics.",
  "_todo_metrics": [
    "viralefy-payments: gateway_callbacks_total{provider,status}, gateway_provider_lookup_duration_seconds — não expostos hoje, só http_requests_total/duration.",
    "viralefy-sender: sender_outbox_dispatch_total{channel,status}, sender_outbox_queue_depth, sender_bounce_total — não expostos hoje.",
    "viralefy-auth: auth_login_attempts_total{result}, auth_jwt_verify_failures_total, auth_2fa_enroll_total, auth_token_mint_total, auth_rate_limit_total — hoje só http_requests_total (com path=/v1/auth/login) e duration.",
    "viralefy-dispatcher: dispatcher_rate_limit_429_total{route}, dispatcher_hotset_size, dispatcher_jwks_cache_hits_total — apenas dispatcher_overhead_seconds/upstream_seconds existem.",
    "viralefy-core: db_query_duration_seconds_bucket{query_type} — declarado no roadmap mas ainda não emitido pelo core."
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "PHASE-9 microservices: core, auth, dispatcher, payments, sender, backoffice, front. Métricas reais por service (label injetada via prometheus.yml).",
